# Copy to .env and fill in. Never commit .env.
# Generate NEXTAUTH_SECRET via: openssl rand -base64 32

# --- Local dev services (match docker-compose.yml port mappings) ---
# Ports 5434 (Postgres) and 6381 (Redis) chosen to avoid collisions with locally
# installed services AND with other running Docker stacks (e.g. legacy genscribe_copy).
DATABASE_URL="postgresql://omniscribe:localpassword@localhost:5434/omniscribe_dev?schema=public"
REDIS_URL="redis://:localpassword@localhost:6381"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # `openssl rand -base64 32`

# --- Email (Unit 01 password reset + invite emails) ---
# Leave RESEND_API_KEY blank in dev — the transport falls back to console-logging
# the email body + URL to the dev-server stdout. Set both to use Resend for real.
RESEND_API_KEY=""
RESEND_FROM="OmniScribe <noreply@omniscribe.local>"

# --- AWS / Bedrock — not used in Unit 01. Documented now to lock the env shape. ---
# CAREFUL: AWS_BEARER_TOKEN_BEDROCK is NOT the same as AWS_ACCESS_KEY_ID.
#   - ABSK… tokens (long-term Bedrock API keys) go in AWS_BEARER_TOKEN_BEDROCK.
#   - SigV4-style IAM credentials go in AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
#   Putting an ABSK token in AWS_ACCESS_KEY_ID triggers UnrecognizedClientException
#   because the SDK then tries SigV4 signing and Bedrock rejects it.
# Sonnet 4.5 / Haiku 4.5 require the cross-region inference profile prefix `us.`.
LLM_PROVIDER="bedrock"
BEDROCK_REGION="us-east-1"
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-5-..."
BEDROCK_FAST_MODEL_ID="us.anthropic.claude-haiku-4-5-..."
AWS_BEARER_TOKEN_BEDROCK=""
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — leave unset unless using SigV4 explicitly.

# --- Soniox (real-time transcription) — Unit 03 ---
# If SONIOX_API_KEY is blank, the SonioxService runs in STUB mode (mints a
# fake key, points at the production WS URL, capture page surfaces "Soniox
# not configured" notice). Useful for local dev without an account.
TRANSCRIPTION_PROVIDER="soniox"
SONIOX_API_KEY=""
# MUST be "true" in any non-dev env that processes PHI (rule 17).
# assertSonioxAllowedForPHI throws at runtime otherwise.
SONIOX_BAA_ON_FILE="false"
SONIOX_REALTIME_MODEL="stt-rt-v4"
SONIOX_REALTIME_WS_URL="wss://stt-rt.soniox.com/transcribe-websocket"
SONIOX_API_BASE="https://api.soniox.com"

# --- S3 (audio storage) — Unit 03 ---
# If S3_AUDIO_BUCKET is blank, audio writes go to ./tmp/audio/ on the
# dev machine via the s3 stub path. Production sets the bucket + relies on
# the IAM task role (rule 13 — never use static access keys in prod).
S3_AUDIO_BUCKET=""
AWS_REGION="us-east-1"

# --- Daily.co (telehealth) — Unit 15 ---
# Blank → stub-mode rooms (URLs like https://stub.daily.co/...). When set,
# the real-mode createRoom path will throw an explicit gap error until the
# integration is wired (Wave 3.5).
DAILY_API_KEY=""
DAILY_BASE_URL="https://api.daily.co/v1"

# --- FHIR / SMART on FHIR — Unit 19 (Wave 4 / F1) ---
# Blank FHIR_NEXTGEN_CLIENT_ID → stub-mode SMART launch (synthetic launch
# token + synthetic access/refresh tokens; same pattern as Soniox / Bedrock).
# Both tokens are AES-256-GCM-encrypted at rest regardless of stub mode.
FHIR_NEXTGEN_CLIENT_ID=""
FHIR_NEXTGEN_CLIENT_SECRET=""
FHIR_NEXTGEN_REDIRECT_URI="http://localhost:3000/api/fhir/callback"
# 32 raw bytes base64-encoded. Generate prod via: openssl rand -base64 32
# The literal below is LOCAL DEV ONLY (the plaintext is the ASCII string
# "LOCAL_DEV_ONLY_KEY_NEVER_USE_PR" + a NUL byte) — never use this value
# in any deployed environment. Production deployments use a fresh random
# value from AWS Secrets Manager.
FHIR_TOKEN_ENCRYPTION_KEY="TE9DQUxfREVWX09OTFlfS0VZX05FVkVSX1VTRV9QUgA="

# --- Platform-owner bootstrap (production day-1) ---
# When set, the app will elevate the user with this email to
# `platformRole=PLATFORM_OWNER` on the first occasion when (a) the email
# matches an existing User row at server boot, OR (b) someone signs up
# with this email — whichever happens first. Idempotent: refuses to fire
# if any PLATFORM_OWNER already exists.
#
# Leave unset in dev — `npx prisma db seed` already creates
# owner@demo.local with the role. Set this on production hosting (Vercel,
# AWS, etc.) to your team's bootstrap email BEFORE first deploy.
#
# After your first owner is established, manage additional platform owners
# via the (forthcoming) /owner/users elevation UI — NOT this env var.
BOOTSTRAP_PLATFORM_OWNER_EMAIL=""
