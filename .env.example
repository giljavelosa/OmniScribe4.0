# Copy to .env and fill in. Never commit .env.
# Generate NEXTAUTH_SECRET via: openssl rand -base64 32

# --- Local dev services (match docker-compose.yml port mappings) ---
DATABASE_URL="postgresql://omniscribe:localpassword@localhost:5433/omniscribe_dev?schema=public"
REDIS_URL="redis://:localpassword@localhost:6380"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # `openssl rand -base64 32`

# --- Email (Unit 01 password reset + invite emails) ---
# Leave RESEND_API_KEY blank in dev — the transport falls back to console-logging
# the email body + URL to the dev-server stdout. Set both to use Resend for real.
RESEND_API_KEY=""
RESEND_FROM="OmniScribe <noreply@omniscribe.local>"

# --- AWS / Bedrock — not used in Unit 01. Documented now to lock the env shape. ---
# CAREFUL: AWS_BEARER_TOKEN_BEDROCK is NOT the same as AWS_ACCESS_KEY_ID.
#   - ABSK… tokens (long-term Bedrock API keys) go in AWS_BEARER_TOKEN_BEDROCK.
#   - SigV4-style IAM credentials go in AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
#   Putting an ABSK token in AWS_ACCESS_KEY_ID triggers UnrecognizedClientException
#   because the SDK then tries SigV4 signing and Bedrock rejects it.
# Sonnet 4.5 / Haiku 4.5 require the cross-region inference profile prefix `us.`.
LLM_PROVIDER="bedrock"
BEDROCK_REGION="us-east-1"
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-5-..."
BEDROCK_FAST_MODEL_ID="us.anthropic.claude-haiku-4-5-..."
AWS_BEARER_TOKEN_BEDROCK=""
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — leave unset unless using SigV4 explicitly.

# --- Soniox (real-time transcription) — not used in Unit 01 ---
TRANSCRIPTION_PROVIDER="soniox"
SONIOX_API_KEY=""
# MUST be "true" in any non-dev env that processes PHI; gates assertProviderAllowedForPHI.
SONIOX_BAA_ON_FILE="false"
SONIOX_REALTIME_MODEL="stt-rt-v4"
