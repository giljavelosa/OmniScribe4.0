  roomId             String?
  visitType          VisitType
  scheduledStart     DateTime
  scheduledEnd       DateTime
  status             ScheduleStatus @default(SCHEDULED)
  notes              String? // admin note, not clinical
  createdAt          DateTime       @default(now())
