// OmniScribe — Unit 01 schema (Foundation Auth & Tenancy)
// Spec: context/specs/01-foundation-auth-tenant.md
//
// Anti-regression rule reminders that bear on this file:
//   #1  Never remove or rename existing models without a migration.
//   #2  Never change NoteStatus enum values (append only). N/A here; lands in Unit 04/05.
//   #4  Run `npx prisma db seed` after schema changes — seed.ts lives next to this file.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum ComplianceProfile {
  STANDARD
  BH_42CFR2
  RESEARCH
}

enum OrgRole {
  ORG_ADMIN
  SITE_ADMIN
  CLINICIAN
  VIEWER
}

enum PlatformRole {
  PLATFORM_OWNER
  /// Unit 33 — operations engineer. Read-only operational visibility:
  /// dashboards, health, queue depths, cross-org audit search. Cannot
  /// provision orgs, edit BAA, change subscription, or impersonate.
  /// Owner is a strict superset of OPS.
  PLATFORM_OPS
  NONE
}

enum Division {
  MEDICAL
  REHAB
  BEHAVIORAL_HEALTH
  MULTI
}

/// Clinician profession (drives default note format + downstream template
/// selection). Free-text `OrgUser.profession` is preserved for sub-specialty
/// detail ("Family Medicine MD"); this enum is the categorical anchor.
enum Profession {
  MD
  DO
  NP
  PA
  OT
  PT
  SLP
  LCSW
  LMFT
  LPC
  PSYCHOLOGIST
  RN
  OTHER
}

enum SeatTier {
  SOLO
  TEAM
  ENTERPRISE
}

enum NoteStyle {
  NARRATIVE
  HYBRID
  HYBRID_BULLET
  STRUCTURED
}

// -----------------------------------------------------------------------------
// Tenancy
// -----------------------------------------------------------------------------

model Organization {
  id               String    @id @default(cuid())
  name             String
  division         Division
  defaultDivision  Division?
  billingEmail     String
  stripeCustomerId String?

  // BAA tracking — required for the Owner console to mark an org "BAA on file".
  // Required at the application layer for new orgs created via /owner/orgs/new;
  // optional at the DB layer so legacy/dev rows can exist without it.
  baaExecutedAt      DateTime?
  baaVersion         String?
  baaCountersignedBy String? // userId of the platform owner who countersigned
  complianceProfile  ComplianceProfile @default(STANDARD)

  // Unit 32 — Owner-facing subscription metadata. Pricing source of truth
  // stays in Stripe (via stripeCustomerId above); this is the at-a-glance
  // tier for owner console triage + the free-text notes field captures
  // sales-approved overrides ("$2k/mo discount through 2026-Q3" etc.).
  // Override notes are length-only in audit metadata — sales context can
  // be sensitive.
  subscriptionPlan          SubscriptionPlan @default(STARTER)
  subscriptionOverrideNotes String? // ≤500 chars enforced at the route

  /// 2026-05-25 — public pricing SKU. Drives seat caps, draft bundles, and
  /// Stripe usage reporting. New orgs land in TRIAL; the Stripe webhook
  /// flips this to the purchased plan on subscription activation. See
  /// references/strategic/stripe-pricing-skus.md for the SKU → Stripe
  /// Product/Price mapping.
  billingPlan          BillingPlan @default(TRIAL)
  /// Stripe Subscription id for the active billing plan. Null while in
  /// TRIAL (no Stripe subscription yet) or for legacy seed orgs. The
  /// subscription's metered usage line is reported daily by
  /// `scripts/billing-usage-report.ts`.
  stripeSubscriptionId String?

  /// Unit 34 — Per-org audit retention in days. null = retain forever.
  auditRetentionDays Int?

  /// Unit 35 — Per-org monthly LLM budget in USD. null = no threshold.
  monthlyLlmBudgetUsd Decimal? @db.Decimal(10, 2)

  /// Unit 51 — Cached org-wide visit bank balance (ledger is source of truth).
  visitBankBalance Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites                  Site[]
  orgUsers               OrgUser[]
  seats                  Seat[]
  invites                Invite[]
  featureFlags           FeatureFlag[]
  ipAllowlistEntries     IpAllowlistEntry[]
  patients               Patient[]
  departments            Department[]
  noteTemplates          NoteTemplate[]
  noteBriefs             NoteBrief[]
  followUps              FollowUp[]
  telehealthSessions     TelehealthSession[]
  fhirIdentities         FhirIdentity[]
  ehrConnections         OrgEhrConnection[]
  usageDaily             OrgUsageDaily[]
  llmCalls               LlmCallLog[]
  llmCostDaily           OrgLlmCostDaily[]
  externalContexts       ExternalContext[]
  caseManagements        CaseManagement[]
  caseRouterRuns         CaseRouterRun[]
  // Sprint 0.14 — Miss Cleo's per-(patient × clinician) memory + chat threads.
  copilotPatientStates   CopilotPatientState[]
  copilotConversations   CopilotConversation[]
  // Sprint 0.16 — FHIR reconciliation drift log (back-relation only).
  caseFhirDriftLogs      CaseFhirDriftLog[]
  // Sprint 0.17 — FHIR write-back proposals (back-relation only).
  fhirWriteBackProposals FhirWriteBackProposal[]
  // Sprint 0.18 — Cleo's proactive nudges (back-relation only).
  cleoNudges             CleoNudge[]
  // Unit 51 — commercial capacity.
  commercialContract     OrganizationCommercialContract?
  visitLedgerEntries     VisitLedgerEntry[]
  visitCapacityRequests  VisitCapacityRequest[]

  @@index([baaExecutedAt])
  @@index([subscriptionPlan])
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

/// 2026-05-25 — public pricing tiers (the consumer-facing SKUs).
///
/// Distinct from `SubscriptionPlan` (the owner-console-facing tier label
/// that pre-dates the public pricing decision and is still used by the
/// existing `/owner/orgs/[id]` UI). Both columns coexist intentionally:
/// `subscriptionPlan` is editable by the platform owner for sales-driven
/// overrides; `billingPlan` is the SKU the customer is paying for via
/// Stripe and drives seat caps + draft bundles + Stripe usage reporting.
///
/// One-to-one mapping with the Stripe Product objects documented in
/// `references/strategic/stripe-pricing-skus.md`. Adding a value here
/// requires creating the corresponding Stripe Product + Price BEFORE
/// deploying — `src/lib/billing/plan-policy.ts` will throw on a plan
/// without a registered policy.
enum BillingPlan {
  /// Trial — no charge; 14-day free trial cap. New orgs default here.
  TRIAL
  /// Solo Starter — $99/mo · 60 drafts · $1.99/draft overage · 1 user.
  SOLO_STARTER
  /// Solo Pro — $179/mo · 160 drafts · $1.49/draft overage · 1 user.
  SOLO_PRO
  /// Solo Power — $299/mo · 300 drafts · $1.29/draft overage · 1 user.
  SOLO_POWER
  /// Solo Unlimited (optional) — $349/mo · unlimited drafts (soft fair-use) · 1 user.
  SOLO_UNLIMITED
  /// Duo — $149/seat · exactly 2 users · 120 drafts/seat. Anti-credential-
  /// sharing wedge: priced just above sharing-savings threshold so two
  /// clinicians who'd split a Solo Pro convert to legitimate Duo seats.
  DUO
  /// Practice — $179/seat · 3+ users · 160 drafts/seat. Volume tiers via
  /// Stripe price ladder; the BillingPlan stays PRACTICE for all volumes.
  PRACTICE
  /// Enterprise — custom contract; seat caps + draft bundles negotiated.
  ENTERPRISE
}

/// Unit 32 — Owner console usage rollup cache.
///
/// One row per org × day (UTC midnight buckets). Populated on-demand
/// when the owner opens an org page; if the row is missing OR its
/// `computedAt` is > 60 minutes old, the route recomputes synchronously
/// before render. No background job in v1 — promotes to BullMQ when the
/// owner page becomes hot.
///
/// `computedAtSourceCount` is a debug breadcrumb so an operator can
/// distinguish "row exists but counted zero events" from "row was
/// never recomputed against fresh data."
model OrgUsageDaily {
  id                    String       @id @default(cuid())
  orgId                 String
  organization          Organization @relation(fields: [orgId], references: [id])
  day                   DateTime // midnight UTC of the calendar day
  notesSigned           Int          @default(0)
  transcriptionMinutes  Int          @default(0)
  copilotAsks           Int          @default(0)
  draftsAccepted        Int          @default(0)
  computedAt            DateTime
  computedAtSourceCount Int          @default(0)

  @@unique([orgId, day])
  @@index([orgId, day])
}

/// Unit 35 — Per-call LLM usage log. One row per LLM generate call
/// when the caller passes a `meter` option. PHI-free by construction
/// — columns are model id + token counts + cost + caller-supplied
/// surface tag. NEVER stores prompts or responses.
///
/// `costUsd` is computed AT THE TIME of the call and stored, NOT
/// recomputed on read. Matches accounting reality + insulates the
/// rollup from future MODEL_PRICING edits.
model LlmCallLog {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  noteId       String? // optional — anchor to a Note when applicable
  surface      String // 'copilot.ask', 'worker.brief', etc.
  model        String // Bedrock model id (cross-region prefix included)
  tokensIn     Int
  tokensOut    Int
  costUsd      Decimal      @db.Decimal(12, 4)
  latencyMs    Int
  stub         Boolean      @default(false)
  createdAt    DateTime     @default(now())

  @@index([orgId, createdAt])
  @@index([surface])
}

/// Unit 35 — Per-org per-day LLM cost rollup cache. Mirrors
/// OrgUsageDaily; 60-minute freshness window; recomputed on-demand
/// from LlmCallLog when stale.
model OrgLlmCostDaily {
  id             String       @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id])
  day            DateTime // midnight UTC
  totalTokensIn  Int          @default(0)
  totalTokensOut Int          @default(0)
  totalCostUsd   Decimal      @default(0) @db.Decimal(12, 4)
  callCount      Int          @default(0)
  computedAt     DateTime

  @@unique([orgId, day])
  @@index([orgId, day])
}

model Site {
  id              String       @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id])
  name            String
  address         String?
  phone           String?
  primaryDivision Division?
  isArchived      Boolean      @default(false)
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())

  rooms       Room[]
  patients    Patient[]
  departments Department[]
  enrollments OrgUserSite[]

  @@index([orgId])
}

model Room {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id])
  name       String
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([siteId])
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String?
  image            String?
  passwordHash     String
  // Signing-PIN MVP — provider sets a 4-digit PIN once, used to unlock sign
  // actions for a grace window (signUnlockedUntil) instead of re-prompting
  // TOTP per signature. Bcrypt-hashed at rest.
  signingPinHash    String?
  signUnlockedUntil DateTime?
  platformRole      PlatformRole @default(NONE)
  /// Unit 37 — Account lockout. Incremented on every wrong-password
  /// attempt; cleared on successful auth (or when a fresh attempt
  /// succeeds after lockedUntil has passed). Threshold = 5 →
  /// 15-minute auto-lock.
  failedLoginCount  Int          @default(0)
  /// When set, NextAuth authorize() returns null until this time
  /// passes — regardless of password correctness — so an attacker
  /// pinging a locked account doesn't get "lock cleared but wrong
  /// password" timing artifacts.
  lockedUntil       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  orgUsers                 OrgUser[]
  sessions                 UserSession[]
  passwordResetTokens      PasswordResetToken[]
  caseRouterAccepts        CaseRouterRun[]         @relation("CaseRouterAcceptedBy")
  // Sprint 0.16 — drift logs resolved by this user (back-relation only).
  caseFhirDriftResolutions CaseFhirDriftLog[]      @relation("CaseFhirDriftResolvedBy")
  // Sprint 0.17 — FHIR write-back proposal authorship + lifecycle.
  fhirWriteBackProposed    FhirWriteBackProposal[] @relation("FhirWriteBackProposedBy")
  fhirWriteBackApproved    FhirWriteBackProposal[] @relation("FhirWriteBackApprovedBy")
  fhirWriteBackCancelled   FhirWriteBackProposal[] @relation("FhirWriteBackCancelledBy")
  // Sprint 0.18 — Cleo nudge lifecycle (back-relations only).
  cleoNudgesDismissed      CleoNudge[]             @relation("CleoNudgeDismissedBy")
  cleoNudgesSnoozed        CleoNudge[]             @relation("CleoNudgeSnoozedBy")
  cleoNudgesActed          CleoNudge[]             @relation("CleoNudgeActedBy")
}

model OrgUser {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  orgId              String
  organization       Organization @relation(fields: [orgId], references: [id])
  role               OrgRole
  division           Division
  /// Categorical profession (drives default note format). Required for the
  /// /capture gate but nullable in DB so the column is additive — clinicians
  /// without it set hit `/onboarding/profile` on next clinical-route load.
  professionType     Profession?
  profession         String?
  canManagePatients  Boolean      @default(false)
  preferredNoteStyle NoteStyle    @default(HYBRID)
  isActive           Boolean      @default(true)
  /// Unit 51 — Per-clinician visit wallet (admin-allocated from org bank).
  visitWalletBalance Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  seatId                 String?               @unique
  seat                   Seat?                 @relation(fields: [seatId], references: [id])
  practitionerProfile    PractitionerProfile?
  fhirIdentities         FhirIdentity[]        @relation("FhirIdentityClinician")
  externalContextsAdded  ExternalContext[]     @relation("ExternalContextAddedBy")
  siteEnrollments        OrgUserSite[]         @relation("OrgUserSiteMember")
  siteEnrollmentsCreated OrgUserSite[]         @relation("OrgUserSiteEnroller")
  voiceProfile           VoiceProfile?
  // Sprint 0.14 — per-clinician Cleo memory + persistent chat threads.
  copilotPatientStates   CopilotPatientState[]
  copilotConversations   CopilotConversation[]
  // Sprint 0.18 — Cleo's proactive nudges, scoped to this clinician.
  cleoNudges             CleoNudge[]
  visitLedgerEntries     VisitLedgerEntry[]
  visitCapacityRequests  VisitCapacityRequest[] @relation("VisitRequestRequester")
  visitCapacityReviews   VisitCapacityRequest[] @relation("VisitRequestReviewer")

  @@unique([userId, orgId])
  @@index([orgId, role])
}

model Seat {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  tier         SeatTier
  expiresAt    DateTime
  /// A seat is usable only when isActive AND expiresAt is in the future.
  /// The Stripe webhook flips this to false on subscription downgrade/cancel
  /// rather than hard-deleting the row, so its assignment + transfer history
  /// survive for the audit trail.
  isActive     Boolean      @default(true)
  /// The Stripe Subscription (sub_…) that paid for this seat. Null for
  /// seed/legacy seats with no Stripe origin. Seat reconciliation matches
  /// DB rows to a Stripe subscription on this column.
  stripeSubId  String?
  createdAt    DateTime     @default(now())

  assignedTo OrgUser?
  transfers  SeatTransfer[]

  @@index([orgId])
  @@index([orgId, stripeSubId])
}

/// Append-only audit trail of seat assignment changes (assign / reassign /
/// revoke). One row per change. fromOrgUserId / toOrgUserId reference
/// OrgUser.id; a null toOrgUserId means the seat was revoked back to the
/// unassigned pool.
model SeatTransfer {
  id            String   @id @default(cuid())
  seatId        String
  seat          Seat     @relation(fields: [seatId], references: [id])
  fromOrgUserId String?
  toOrgUserId   String?
  reason        String?
  transferredAt DateTime @default(now())

  @@index([seatId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PractitionerProfile {
  id          String   @id @default(cuid())
  orgUserId   String   @unique
  orgUser     OrgUser  @relation(fields: [orgUserId], references: [id])
  npi         String?
  specialty   String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invite {
  id                String       @id @default(cuid())
  email             String
  orgId             String
  organization      Organization @relation(fields: [orgId], references: [id])
  role              OrgRole
  division          Division
  professionType    Profession?
  profession        String?
  canManagePatients Boolean      @default(false)
  token             String       @unique
  expiresAt         DateTime
  consumedAt        DateTime?
  consumedByUserId  String?
  invitedByUserId   String
  createdAt         DateTime     @default(now())

  @@index([orgId, email])
}

// -----------------------------------------------------------------------------
// Password reset (D6 — separate model preserves audit history; chosen over
// transient fields on User so consumed/expired tokens stay queryable).
// -----------------------------------------------------------------------------

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique // bcrypt-hashed; never store raw token
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt])
}

// -----------------------------------------------------------------------------
// Audit (anti-regression rule 8: audit writes NEVER wrapped in swallowing
// try-catch. Both tables are append-only at the application layer.)
// -----------------------------------------------------------------------------

model AuditLog {
  id               String   @id @default(cuid())
  userId           String?
  orgId            String?
  actingUserId     String? // for impersonation: the platform owner acting
  onBehalfOfUserId String? // for impersonation: the user they're acting as
  action           String // e.g. USER_SIGNED_IN, NOTE_SIGNED, ORG_BAA_UPDATED
  resourceType     String?
  resourceId       String?
  metadata         Json? // PHI-free (enforced at the writer; see src/lib/audit/phi-free-check.ts)
  createdAt        DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([userId, createdAt])
}

model PlatformAuditLog {
  id           String   @id @default(cuid())
  actingUserId String
  action       String
  resourceType String?
  resourceId   String?
  metadata     Json? // PHI-free
  createdAt    DateTime @default(now())

  @@index([actingUserId, createdAt])
}

model PlatformSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Org config / ops controls
// -----------------------------------------------------------------------------

model FeatureFlag {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  key          String
  value        Json

  @@unique([orgId, key])
}

model SystemAnnouncement {
  id              String    @id @default(cuid())
  title           String
  body            String // markdown
  severity        String // 'info' | 'warning' | 'critical'
  targetOrgIds    String[] // empty array = visible to all orgs
  startsAt        DateTime
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String
}

model IpAllowlistEntry {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  cidr         String
  description  String?
  createdAt    DateTime     @default(now())

  @@index([orgId])
}

