/// Unit 48 — clinical intent of an encounter (distinct from Schedule.visitType
/// which is modality only). Miss Cleo proposes at start; clinician confirms or
/// overrides; the value is recorded at Encounter create time and shapes the
/// brief spine, the suggested-data list (future), and the note-generator
/// template default (future). Append-only per rule 2.
/// See: references/visit-type-taxonomy.md
enum EncounterIntent {
  UNSPECIFIED
  // REHAB (PT/OT/SLP) per CMS Pub. 100-02 Ch. 15 §220
  REHAB_INITIAL_EVAL
  REHAB_DAILY_NOTE
  REHAB_PROGRESS_NOTE
  REHAB_REEVAL
  REHAB_DISCHARGE
  // BEHAVIORAL_HEALTH
  BH_INITIAL_ASSESSMENT
  BH_SESSION_INDIVIDUAL
  BH_SESSION_FAMILY
  BH_SESSION_GROUP
  BH_TREATMENT_PLAN_REVIEW
  BH_CRISIS_REASSESSMENT
  BH_DISCHARGE
  // MEDICAL — 2021 E/M guidelines + AWV + TCM
  MEDICAL_NEW_PATIENT
  MEDICAL_FOLLOW_UP
  MEDICAL_ANNUAL_WELLNESS
  MEDICAL_CHRONIC_CARE
  MEDICAL_ACUTE_VISIT
  MEDICAL_DISCHARGE_TCM
  MEDICAL_TELEHEALTH_CHECKIN
}

/// Unit 48 — provenance of Encounter.intent. Append-only per rule 2.
enum IntentSource {
  /// Clinician picked or confirmed at start-visit time.
  CLINICIAN
  /// Cleo proposed and the clinician took the default without override.
  COPILOT_PROPOSAL_CONFIRMED
  /// Inherited from the schedule (notes / template).
  SCHEDULE
}

enum CaseManagementStatus {
  ACTIVE
  CLOSED
  CANCELLED
  /// Sprint 0.13 — encounter is bound while Miss Cleo's case-router agent
  /// proposes the destination case at review time. Append-only per rule 2.
  PENDING_ROUTER
}

/// Sprint 0.16 — first-introduction; append-only thereafter. Future kinds
/// (e.g. RECORDER, ONSET_DATE, ALLERGY, MEDICATION) extend additively.
enum CaseFhirDriftKind {
  /// `Condition.clinicalStatus` disagrees with the derived state from
  /// `CaseManagement.status` (e.g. case ACTIVE + Condition resolved).
  STATUS
  /// `Condition.code` (latest coded) differs from `CaseManagement.primaryIcd`.
  ICD
}

/// Sprint 0.17 — FHIR Phase D₃ write-back operation discriminator.
/// CREATE = POST a new Condition resource. PATCH = PATCH an existing
/// Condition (status or ICD change). No DELETE ever — clinical history
/// is forever (decision 4); closing a case PATCHes clinicalStatus.
enum FhirWriteBackOperation {
  CREATE
  PATCH
}

/// Sprint 0.17 — FHIR write-back proposal state machine. Transitions:
///   PROPOSED → APPROVED → EXECUTING → SUCCEEDED
///                                  ↘ FAILED → (retry: APPROVED)
///                                  ↘ CANCELLED
///   PROPOSED → CANCELLED
///   FAILED   → CANCELLED
/// Terminal states: SUCCEEDED, CANCELLED. FAILED is non-terminal when
/// `failureKind = TRANSIENT` (the UI offers Retry); terminal otherwise.
enum FhirWriteBackStatus {
  /// Inserted by the accept endpoint; awaiting clinician approval click.
  PROPOSED
  /// Clinician clicked Confirm in the review-panel dialog; job enqueued.
  APPROVED
  /// Worker picked up the job and is mid-write.
  EXECUTING
  /// Worker wrote successfully; FHIR id stored on the proposal (and
  /// back-filled to CaseManagement.mirrorsFhirConditionId for CREATE).
  SUCCEEDED
  /// Worker failed; `failureKind` set + UI offers Retry/Cancel.
  FAILED
  /// Clinician cancelled OR org-level toggle was flipped off OR the
  /// worker found writebackEnabled = false at job pickup.
  CANCELLED
}

/// Sprint 0.17 — failure taxonomy. The discriminator the UI uses to
/// choose between "Retry" and "Open new proposal" affordances; the
/// worker uses it to decide whether to throw (rule 10 retries) or
/// fail-closed.
enum FhirWriteBackFailureKind {
  /// 5xx / network / timeout — worker throws so BullMQ retries (rule 10).
  TRANSIENT
  /// 401 / 403 / 422 — worker does NOT throw. UI shows
  /// "EHR write blocked — review" and surfaces auth issues to the
  /// org admin separately.
  PERMANENT
  /// 412 If-Match precondition (EHR moved out from under us between
  /// drift detection and this write). Worker does NOT throw; UI
  /// surfaces the new EHR state + offers to re-read + propose afresh.
  CONFLICT
}

/// Sprint 0.18 — discriminator for proactive nudge cards. Each kind
/// maps 1:1 to a pattern detector (Sprint 0.14 + 0.16 + 0.17). Future
/// kinds extend this enum additively; spec §5 / decision 11 forbids
/// inventing new kinds outside a planned sprint to keep the
/// generator deterministic + auditable.
enum CleoNudgeKind {
  RECERT_DUE_SOON
  CASE_FHIR_STATUS_DRIFT
  FHIR_WRITEBACK_FAILED_PERMANENT
  MEASURE_TREND
  GOAL_STALLED
  TOPIC_MENTIONED_UNADDRESSED
}

/// Sprint 0.18 — priority chip variant. Drives the `<StatusBadge>`
/// variant in the UI (warning / info / neutral) per rule 23 — no
/// hardcoded status colors. Hardcoded per-kind in `nudge-selector.ts`;
/// not clinician-tunable in this sprint.
enum CleoNudgePriority {
  HIGH
  MEDIUM
  LOW
}

/// Sprint 0.18 — nudge state machine. Terminal states: ACTED,
/// DISMISSED, EXPIRED. SNOOZED is non-terminal (the read-time filter
/// re-surfaces once `snoozeUntil` passes). PROPOSED + SHOWN are
/// pre-action; SHOWN audit only fires on first component mount.
enum CleoNudgeStatus {
  /// Generator created the row; not yet rendered.
  PROPOSED
  /// First-mount audit fired; clinician saw it (decision 5).
  SHOWN
  /// One-tap dismissal; cooldown begins per `nudge-selector.ts`.
  DISMISSED
  /// Defer until `snoozeUntil`; re-surfaces automatically at next read.
  SNOOZED
  /// Clinician pressed the contextual affordance; navigated to the
  /// matching screen. Idempotent.
  ACTED
  /// Underlying pattern resolved; auto-expired at read time.
  EXPIRED
}

/// Sprint 0.18 — eligible surface for a nudge row. Spec decision 2:
/// most nudges are valid on both the chart and the visit-prepare
/// surface; a few kinds are surface-locked (e.g. recert-due-soon makes
/// sense on the chart hero AND on visit-prepare, while a
/// goal-stalled nudge primarily fits visit-prepare). `BOTH` is the
/// common case; the read-time filter narrows when needed.
enum CleoNudgeSurface {
  CHART
  VISIT_PREPARE
  BOTH
}

/// Sprint 0.13 — confidence the case-router agent expressed in its proposal.
/// HIGH = pre-select + primary "Confirm" CTA. MEDIUM = pre-select + reasoning
/// expanded by default. LOW = no pre-selection; clinician picks from peers.
enum RouterConfidence {
  HIGH
  MEDIUM
  LOW
}

enum EpisodeStatus {
  ACTIVE
  RECERT_DUE
  DISCHARGED
  CANCELLED
}

enum GoalStatus {
  ACTIVE
  MET
  NOT_MET
  MODIFIED
  DISCONTINUED
  PARTIALLY_MET
}

enum GoalType {
  STG
  LTG
}

enum NoteSensitivityLevel {
  STANDARD_CLINICAL
  BEHAVIORAL_HEALTH
  BILLING_ONLY
  ADMINISTRATIVE
}

// NoteStatus — APPEND-ONLY per anti-regression rule 2.
// Unit 02 shipped PREPARING; Unit 03 appended RECORDING/PAUSED/TRANSCRIBING.
// Unit 04 appended DRAFTING + INTERRUPTED.
// Unit 05 appends DRAFT (sections all populated; ready for clinician review),
// REVIEWING (clinician actively in /review), SIGNED (finalJson frozen),
// TRANSFERRED (post-sign hand-off — EHR push when FHIR write lands),
// PENDING_REVIEW (auto-paused waiting for clinician attention).
//
// Canonical transition graph (spec §G):
//   PREPARING → RECORDING → (PAUSED ↔ RECORDING) → TRANSCRIBING → DRAFTING
//                                                       ↓               ↓
//                                                   INTERRUPTED     DRAFT → REVIEWING → SIGNED → (TRANSFERRED)
enum NoteStatus {
  PREPARING
  RECORDING
  PAUSED
  TRANSCRIBING
  DRAFTING
  INTERRUPTED
  DRAFT
  REVIEWING
  SIGNED
  TRANSFERRED
  PENDING_REVIEW
}

// NoteArtifactKind — post-sign generated documents that are SEPARATE from
// finalJson. They never modify the signed note (rule 3); they're sibling
// records produced by the post-sign-artifacts worker.
enum NoteArtifactKind {
  PATIENT_INSTRUCTIONS
  REFERRAL_LETTER
}

// CaptureMode — how the audio/transcript got into the system.
//   LIVE      → AudioWorklet + Soniox real-time WS (default for `/capture`)
//   UPLOADED  → clinician picked an existing audio file → Soniox batch path
//   PASTED    → clinician pasted a transcript directly (no audio; skips transcription)
enum CaptureMode {
  LIVE
  UPLOADED
  PASTED
}

model Patient {
