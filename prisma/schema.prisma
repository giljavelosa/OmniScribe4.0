  firstName         String
  lastName          String
  mrn               String?
  dob               DateTime
  sex               PatientSex
  phone             String?
  email             String?
  preferredLanguage String?
  isDeleted         Boolean      @default(false)
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  addresses                PatientAddress[]
  coverages                PatientCoverage[]
  emergencyContacts        PatientEmergencyContact[]
  guarantors               PatientGuarantor[]
  consents                 PatientConsent[]
  communicationPreferences PatientCommunicationPreference[]
  enrollments              PatientDepartmentEnrollment[]
  intakes                  PatientDepartmentIntake[]
  encounters               Encounter[]
  schedules                Schedule[]
  caseManagements          CaseManagement[]
  episodes                 EpisodeOfCare[]
  notes                    Note[]
  briefs                   NoteBrief[]
  followUps                FollowUp[]
  snapshotOverrides        SnapshotOverride[]
  telehealthSessions       TelehealthSession[]
  fhirIdentities           PatientFhirIdentity[]
  fhirCachedResources      FhirCachedResource[]
  externalContexts         ExternalContext[]
  // Sprint 0.14 — Miss Cleo memory + chat threads anchored to this patient.
  copilotPatientStates     CopilotPatientState[]
  copilotConversations     CopilotConversation[]
  // Sprint 0.16 — FHIR reconciliation drift log (back-relation only).
  caseFhirDriftLogs        CaseFhirDriftLog[]
  // Sprint 0.17 — FHIR write-back proposals (back-relation only).
  fhirWriteBackProposals   FhirWriteBackProposal[]
  // Sprint 0.18 — Cleo's proactive nudges anchored to this patient.
