// OmniScribe — Unit 01 schema (Foundation Auth & Tenancy)
// Spec: context/specs/01-foundation-auth-tenant.md
//
// Anti-regression rule reminders that bear on this file:
//   #1  Never remove or rename existing models without a migration.
//   #2  Never change NoteStatus enum values (append only). N/A here; lands in Unit 04/05.
//   #4  Run `npx prisma db seed` after schema changes — seed.ts lives next to this file.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum ComplianceProfile {
  STANDARD
  BH_42CFR2
  RESEARCH
}

enum OrgRole {
  ORG_ADMIN
  SITE_ADMIN
  CLINICIAN
  VIEWER
}

enum PlatformRole {
  PLATFORM_OWNER
  /// Unit 33 — operations engineer. Read-only operational visibility:
  /// dashboards, health, queue depths, cross-org audit search. Cannot
  /// provision orgs, edit BAA, change subscription, or impersonate.
  /// Owner is a strict superset of OPS.
  PLATFORM_OPS
  NONE
}

enum Division {
  MEDICAL
  REHAB
  BEHAVIORAL_HEALTH
  MULTI
}

/// Clinician profession (drives default note format + downstream template
/// selection). Free-text `OrgUser.profession` is preserved for sub-specialty
/// detail ("Family Medicine MD"); this enum is the categorical anchor.
enum Profession {
  MD
  DO
  NP
  PA
  OT
  PT
  SLP
  LCSW
  LMFT
  LPC
  PSYCHOLOGIST
  RN
  OTHER
}

enum SeatTier {
  SOLO
  TEAM
  ENTERPRISE
}

enum NoteStyle {
  NARRATIVE
  HYBRID
  HYBRID_BULLET
  STRUCTURED
}

// -----------------------------------------------------------------------------
// Tenancy
// -----------------------------------------------------------------------------

model Organization {
  id               String    @id @default(cuid())
  name             String
  division         Division
  defaultDivision  Division?
  billingEmail     String
  stripeCustomerId String?
  forceMfa         Boolean   @default(false)

  // BAA tracking — required for the Owner console to mark an org "BAA on file".
  // Required at the application layer for new orgs created via /owner/orgs/new;
  // optional at the DB layer so legacy/dev rows can exist without it.
  baaExecutedAt      DateTime?
  baaVersion         String?
  baaCountersignedBy String? // userId of the platform owner who countersigned
  complianceProfile  ComplianceProfile @default(STANDARD)

  // Unit 32 — Owner-facing subscription metadata. Pricing source of truth
  // stays in Stripe (via stripeCustomerId above); this is the at-a-glance
  // tier for owner console triage + the free-text notes field captures
  // sales-approved overrides ("$2k/mo discount through 2026-Q3" etc.).
  // Override notes are length-only in audit metadata — sales context can
  // be sensitive.
  subscriptionPlan          SubscriptionPlan @default(STARTER)
  subscriptionOverrideNotes String? // ≤500 chars enforced at the route

  /// Unit 34 — Per-org audit retention in days. null = retain forever.
  auditRetentionDays Int?

  /// Unit 35 — Per-org monthly LLM budget in USD. null = no threshold.
  monthlyLlmBudgetUsd Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites              Site[]
  orgUsers           OrgUser[]
  seats              Seat[]
  invites            Invite[]
  featureFlags       FeatureFlag[]
  ipAllowlistEntries IpAllowlistEntry[]
  patients           Patient[]
  departments        Department[]
  noteTemplates      NoteTemplate[]
  noteBriefs         NoteBrief[]
  followUps          FollowUp[]
  telehealthSessions TelehealthSession[]
  fhirIdentities     FhirIdentity[]
  ehrConnections     OrgEhrConnection[]
  usageDaily         OrgUsageDaily[]
  llmCalls           LlmCallLog[]
  llmCostDaily       OrgLlmCostDaily[]
  externalContexts   ExternalContext[]

  @@index([baaExecutedAt])
  @@index([subscriptionPlan])
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

/// Unit 32 — Owner console usage rollup cache.
///
/// One row per org × day (UTC midnight buckets). Populated on-demand
/// when the owner opens an org page; if the row is missing OR its
/// `computedAt` is > 60 minutes old, the route recomputes synchronously
/// before render. No background job in v1 — promotes to BullMQ when the
/// owner page becomes hot.
///
/// `computedAtSourceCount` is a debug breadcrumb so an operator can
/// distinguish "row exists but counted zero events" from "row was
/// never recomputed against fresh data."
model OrgUsageDaily {
  id                    String       @id @default(cuid())
  orgId                 String
  organization          Organization @relation(fields: [orgId], references: [id])
  day                   DateTime     // midnight UTC of the calendar day
  notesSigned           Int          @default(0)
  transcriptionMinutes  Int          @default(0)
  copilotAsks           Int          @default(0)
  draftsAccepted        Int          @default(0)
  computedAt            DateTime
  computedAtSourceCount Int          @default(0)

  @@unique([orgId, day])
  @@index([orgId, day])
}

/// Unit 35 — Per-call LLM usage log. One row per LLM generate call
/// when the caller passes a `meter` option. PHI-free by construction
/// — columns are model id + token counts + cost + caller-supplied
/// surface tag. NEVER stores prompts or responses.
///
/// `costUsd` is computed AT THE TIME of the call and stored, NOT
/// recomputed on read. Matches accounting reality + insulates the
/// rollup from future MODEL_PRICING edits.
model LlmCallLog {
  id        String       @id @default(cuid())
  orgId     String
  organization Organization @relation(fields: [orgId], references: [id])
  noteId    String?      // optional — anchor to a Note when applicable
  surface   String       // 'copilot.ask', 'worker.brief', etc.
  model     String       // Bedrock model id (cross-region prefix included)
  tokensIn  Int
  tokensOut Int
  costUsd   Decimal      @db.Decimal(12, 4)
  latencyMs Int
  stub      Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([orgId, createdAt])
  @@index([surface])
}

/// Unit 35 — Per-org per-day LLM cost rollup cache. Mirrors
/// OrgUsageDaily; 60-minute freshness window; recomputed on-demand
/// from LlmCallLog when stale.
model OrgLlmCostDaily {
  id             String       @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id])
  day            DateTime     // midnight UTC
  totalTokensIn  Int          @default(0)
  totalTokensOut Int          @default(0)
  totalCostUsd   Decimal      @default(0) @db.Decimal(12, 4)
  callCount      Int          @default(0)
  computedAt     DateTime

  @@unique([orgId, day])
  @@index([orgId, day])
}

model Site {
  id              String       @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id])
  name            String
  address         String?
  phone           String?
  primaryDivision Division?
  isArchived      Boolean      @default(false)
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())

  rooms       Room[]
  patients    Patient[]
  departments Department[]
  enrollments OrgUserSite[]

  @@index([orgId])
}

model Room {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id])
  name       String
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([siteId])
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String?
  image            String?
  passwordHash     String
  mfaSecret        String?
  mfaEnabled       Boolean      @default(false)
  // JSON array of bcrypt-hashed recovery codes; each element is consumed when used.
  mfaRecoveryCodes Json?
  // Signing-PIN MVP — provider sets a 4-digit PIN once, used to unlock sign
  // actions for a grace window (signUnlockedUntil) instead of re-prompting
  // TOTP per signature. Bcrypt-hashed at rest.
  signingPinHash    String?
  signUnlockedUntil DateTime?
  platformRole     PlatformRole @default(NONE)
  /// Unit 37 — Account lockout. Incremented on every wrong-password
  /// attempt; cleared on successful auth (or when a fresh attempt
  /// succeeds after lockedUntil has passed). Threshold = 5 →
  /// 15-minute auto-lock.
  failedLoginCount Int          @default(0)
  /// When set, NextAuth authorize() returns null until this time
  /// passes — regardless of password correctness — so an attacker
  /// pinging a locked account doesn't get "lock cleared but wrong
  /// password" timing artifacts.
  lockedUntil      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  orgUsers            OrgUser[]
  sessions            UserSession[]
  passwordResetTokens PasswordResetToken[]
}

model OrgUser {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  orgId              String
  organization       Organization @relation(fields: [orgId], references: [id])
  role               OrgRole
  division           Division
  /// Categorical profession (drives default note format). Required for the
  /// /capture gate but nullable in DB so the column is additive — clinicians
  /// without it set hit `/onboarding/profile` on next clinical-route load.
  professionType     Profession?
  profession         String?
  canManagePatients  Boolean      @default(false)
  preferredNoteStyle NoteStyle    @default(HYBRID)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  seatId              String?              @unique
  seat                Seat?                @relation(fields: [seatId], references: [id])
  practitionerProfile PractitionerProfile?
  fhirIdentities      FhirIdentity[]       @relation("FhirIdentityClinician")
  externalContextsAdded ExternalContext[]  @relation("ExternalContextAddedBy")
  siteEnrollments     OrgUserSite[]        @relation("OrgUserSiteMember")
  siteEnrollmentsCreated OrgUserSite[]     @relation("OrgUserSiteEnroller")

  @@unique([userId, orgId])
  @@index([orgId, role])
}

model Seat {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  tier         SeatTier
  expiresAt    DateTime
  /// A seat is usable only when isActive AND expiresAt is in the future.
  /// The Stripe webhook flips this to false on subscription downgrade/cancel
  /// rather than hard-deleting the row, so its assignment + transfer history
  /// survive for the audit trail.
  isActive     Boolean      @default(true)
  /// The Stripe Subscription (sub_…) that paid for this seat. Null for
  /// seed/legacy seats with no Stripe origin. Seat reconciliation matches
  /// DB rows to a Stripe subscription on this column.
  stripeSubId  String?
  createdAt    DateTime     @default(now())

  assignedTo OrgUser?
  transfers  SeatTransfer[]

  @@index([orgId])
  @@index([orgId, stripeSubId])
}

/// Append-only audit trail of seat assignment changes (assign / reassign /
/// revoke). One row per change. fromOrgUserId / toOrgUserId reference
/// OrgUser.id; a null toOrgUserId means the seat was revoked back to the
/// unassigned pool.
model SeatTransfer {
  id            String   @id @default(cuid())
  seatId        String
  seat          Seat     @relation(fields: [seatId], references: [id])
  fromOrgUserId String?
  toOrgUserId   String?
  reason        String?
  transferredAt DateTime @default(now())

  @@index([seatId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PractitionerProfile {
  id          String   @id @default(cuid())
  orgUserId   String   @unique
  orgUser     OrgUser  @relation(fields: [orgUserId], references: [id])
  npi         String?
  specialty   String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invite {
  id                String       @id @default(cuid())
  email             String
  orgId             String
  organization      Organization @relation(fields: [orgId], references: [id])
  role              OrgRole
  division          Division
  professionType    Profession?
  profession        String?
  canManagePatients Boolean      @default(false)
  token             String       @unique
  expiresAt         DateTime
  consumedAt        DateTime?
  consumedByUserId  String?
  invitedByUserId   String
  createdAt         DateTime     @default(now())

  @@index([orgId, email])
}

// -----------------------------------------------------------------------------
// Password reset (D6 — separate model preserves audit history; chosen over
// transient fields on User so consumed/expired tokens stay queryable).
// -----------------------------------------------------------------------------

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique // bcrypt-hashed; never store raw token
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt])
}

// -----------------------------------------------------------------------------
// Audit (anti-regression rule 8: audit writes NEVER wrapped in swallowing
// try-catch. Both tables are append-only at the application layer.)
// -----------------------------------------------------------------------------

model AuditLog {
  id               String   @id @default(cuid())
  userId           String?
  orgId            String?
  actingUserId     String? // for impersonation: the platform owner acting
  onBehalfOfUserId String? // for impersonation: the user they're acting as
  action           String // e.g. USER_SIGNED_IN, NOTE_SIGNED, ORG_BAA_UPDATED
  resourceType     String?
  resourceId       String?
  metadata         Json? // PHI-free (enforced at the writer; see src/lib/audit/phi-free-check.ts)
  createdAt        DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([userId, createdAt])
}

model PlatformAuditLog {
  id           String   @id @default(cuid())
  actingUserId String
  action       String
  resourceType String?
  resourceId   String?
  metadata     Json? // PHI-free
  createdAt    DateTime @default(now())

  @@index([actingUserId, createdAt])
}

model PlatformSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Org config / ops controls
// -----------------------------------------------------------------------------

model FeatureFlag {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  key          String
  value        Json

  @@unique([orgId, key])
}

model SystemAnnouncement {
  id              String    @id @default(cuid())
  title           String
  body            String // markdown
  severity        String // 'info' | 'warning' | 'critical'
  targetOrgIds    String[] // empty array = visible to all orgs
  startsAt        DateTime
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String
}

model IpAllowlistEntry {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  cidr         String
  description  String?
  createdAt    DateTime     @default(now())

  @@index([orgId])
}

// =============================================================================
// Unit 02 — Patient & Schedule Core
// Spec: context/specs/02-patient-and-schedule.md
// =============================================================================

enum PatientSex {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum PatientAddressKind {
  HOME
  WORK
  OTHER
}

enum PatientCoverageStatus {
  ACTIVE
  TERMINATED
  PENDING
  UNKNOWN
}

enum PatientConsentStatus {
  GIVEN
  DECLINED
  PENDING
  REVOKED
}

enum PatientDepartmentEnrollmentStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  WAITLIST
}

enum PatientDepartmentIntakeStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  ARCHIVED
}

enum VisitType {
  IN_PERSON
  TELEHEALTH
}

enum ScheduleStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum EncounterStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EpisodeStatus {
  ACTIVE
  RECERT_DUE
  DISCHARGED
  CANCELLED
}

enum GoalStatus {
  ACTIVE
  MET
  NOT_MET
  MODIFIED
  DISCONTINUED
  PARTIALLY_MET
}

enum GoalType {
  STG
  LTG
}

enum NoteSensitivityLevel {
  STANDARD_CLINICAL
  BEHAVIORAL_HEALTH
  BILLING_ONLY
  ADMINISTRATIVE
}

// NoteStatus — APPEND-ONLY per anti-regression rule 2.
// Unit 02 shipped PREPARING; Unit 03 appended RECORDING/PAUSED/TRANSCRIBING.
// Unit 04 appended DRAFTING + INTERRUPTED.
// Unit 05 appends DRAFT (sections all populated; ready for clinician review),
// REVIEWING (clinician actively in /review), SIGNED (finalJson frozen),
// TRANSFERRED (post-sign hand-off — EHR push when FHIR write lands),
// PENDING_REVIEW (auto-paused waiting for clinician attention).
//
// Canonical transition graph (spec §G):
//   PREPARING → RECORDING → (PAUSED ↔ RECORDING) → TRANSCRIBING → DRAFTING
//                                                       ↓               ↓
//                                                   INTERRUPTED     DRAFT → REVIEWING → SIGNED → (TRANSFERRED)
enum NoteStatus {
  PREPARING
  RECORDING
  PAUSED
  TRANSCRIBING
  DRAFTING
  INTERRUPTED
  DRAFT
  REVIEWING
  SIGNED
  TRANSFERRED
  PENDING_REVIEW
}

// NoteArtifactKind — post-sign generated documents that are SEPARATE from
// finalJson. They never modify the signed note (rule 3); they're sibling
// records produced by the post-sign-artifacts worker.
enum NoteArtifactKind {
  PATIENT_INSTRUCTIONS
  REFERRAL_LETTER
}

// CaptureMode — how the audio/transcript got into the system.
//   LIVE      → AudioWorklet + Soniox real-time WS (default for `/capture`)
//   UPLOADED  → clinician picked an existing audio file → Soniox batch path
//   PASTED    → clinician pasted a transcript directly (no audio; skips transcription)
enum CaptureMode {
  LIVE
  UPLOADED
  PASTED
}

model Patient {
  id                String       @id @default(cuid())
  orgId             String
  organization      Organization @relation(fields: [orgId], references: [id])
  siteId            String?
  site              Site?        @relation(fields: [siteId], references: [id])
  firstName         String
  lastName          String
  mrn               String?
  dob               DateTime
  sex               PatientSex
  phone             String?
  email             String?
  preferredLanguage String?
  isDeleted         Boolean      @default(false)
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  addresses                PatientAddress[]
  coverages                PatientCoverage[]
  emergencyContacts        PatientEmergencyContact[]
  guarantors               PatientGuarantor[]
  consents                 PatientConsent[]
  communicationPreferences PatientCommunicationPreference[]
  enrollments              PatientDepartmentEnrollment[]
  intakes                  PatientDepartmentIntake[]
  encounters               Encounter[]
  schedules                Schedule[]
  episodes                 EpisodeOfCare[]
  notes                    Note[]
  briefs                   NoteBrief[]
  followUps                FollowUp[]
  snapshotOverrides        SnapshotOverride[]
  telehealthSessions       TelehealthSession[]
  fhirIdentities           PatientFhirIdentity[]
  fhirCachedResources      FhirCachedResource[]
  externalContexts         ExternalContext[]

  @@unique([orgId, mrn])
  @@index([orgId, lastName, firstName])
  @@index([orgId, isDeleted])
}

model PatientAddress {
  id         String             @id @default(cuid())
  patientId  String
  patient    Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  kind       PatientAddressKind
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String             @default("US")

  @@index([patientId])
}

model PatientCoverage {
  id              String                @id @default(cuid())
  patientId       String
  patient         Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  carrier         String
  planName        String?
  memberId        String
  groupId         String?
  status          PatientCoverageStatus @default(ACTIVE)
  effectiveDate   DateTime?
  terminationDate DateTime?

  @@index([patientId])
}

model PatientEmergencyContact {
  id           String  @id @default(cuid())
  patientId    String
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  relationship String?
  phone        String?
  email        String?

  @@index([patientId])
}

model PatientGuarantor {
  id           String  @id @default(cuid())
  patientId    String
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  relationship String?
  phone        String?
  email        String?
  address      String?

  @@index([patientId])
}

model PatientConsent {
  id          String               @id @default(cuid())
  patientId   String
  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consentType String // 'recording' | 'voice-id' | 'telehealth' | etc.
  status      PatientConsentStatus
  version     String
  acceptedAt  DateTime?
  declinedAt  DateTime?

  @@index([patientId])
}

model PatientCommunicationPreference {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  channel   String // 'email' | 'sms' | 'phone' | 'portal'
  optedIn   Boolean

  @@index([patientId])
}

model Department {
  id               String       @id @default(cuid())
  orgId            String
  organization     Organization @relation(fields: [orgId], references: [id])
  siteId           String? // null = org-wide
  site             Site?        @relation(fields: [siteId], references: [id])
  name             String
  division         Division
  intakeFormSchema Json? // JSON schema for intake form

  enrollments PatientDepartmentEnrollment[]
  intakes     PatientDepartmentIntake[]
  encounters  Encounter[]
  episodes    EpisodeOfCare[]

  @@index([orgId])
}

model PatientDepartmentEnrollment {
  id           String                            @id @default(cuid())
  patientId    String
  patient      Patient                           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  orgId        String
  departmentId String
  department   Department                        @relation(fields: [departmentId], references: [id])
  status       PatientDepartmentEnrollmentStatus
  enrolledAt   DateTime                          @default(now())
  endedAt      DateTime?

  @@index([patientId])
  @@index([departmentId, status])
}

model PatientDepartmentIntake {
  id               String                        @id @default(cuid())
  patientId        String
  patient          Patient                       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  departmentId     String
  department       Department                    @relation(fields: [departmentId], references: [id])
  status           PatientDepartmentIntakeStatus
  sensitivityLevel NoteSensitivityLevel          @default(STANDARD_CLINICAL)
  formData         Json
  submittedAt      DateTime?
  reviewedAt       DateTime?

  @@index([patientId])
  @@index([departmentId, status])
}

model Schedule {
  id                 String         @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient        @relation(fields: [patientId], references: [id])
  clinicianOrgUserId String
  siteId             String
  roomId             String?
  visitType          VisitType
  scheduledStart     DateTime
  scheduledEnd       DateTime
  status             ScheduleStatus @default(SCHEDULED)
  notes              String? // admin note, not clinical
  createdAt          DateTime       @default(now())
  /**
   * Optional pre-link to a specific episode at scheduling time. When set, the
   * start-visit pipeline inherits the episode without prompting the clinician
   * at /home. Null = no pre-link; the picker may fire at start time if the
   * patient has 2+ active episodes.
   */
  episodeOfCareId    String?
  episode            EpisodeOfCare? @relation(fields: [episodeOfCareId], references: [id])

  encounter Encounter?
  /** Unit 15 — 1:1 telehealth session when visitType=TELEHEALTH. */
  telehealthSession TelehealthSession?

  @@index([clinicianOrgUserId, scheduledStart])
  @@index([orgId, scheduledStart])
  @@index([episodeOfCareId])
}

model Encounter {
  id                 String          @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id])
  scheduleId         String?         @unique
  schedule           Schedule?       @relation(fields: [scheduleId], references: [id])
  clinicianOrgUserId String
  siteId             String
  roomId             String?
  departmentId       String?
  department         Department?     @relation(fields: [departmentId], references: [id])
  episodeOfCareId    String?
  episode            EpisodeOfCare?  @relation(fields: [episodeOfCareId], references: [id])
  status             EncounterStatus @default(PLANNED)
  startedAt          DateTime?
  endedAt            DateTime?

  notes Note[]

  @@index([patientId, startedAt])
}

model EpisodeOfCare {
  id                 String        @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient       @relation(fields: [patientId], references: [id])
  clinicianOrgUserId String
  departmentId       String
  department         Department    @relation(fields: [departmentId], references: [id])
  division           Division
  diagnosis          String
  bodyPart           String?
  status             EpisodeStatus @default(ACTIVE)
  startedAt          DateTime      @default(now())
  endedAt            DateTime?
  recertDueAt        DateTime?
  /** Configurable per-episode recert cadence. Default 90 days; API layer
   *  enforces min 7, max 365 (Unit 11). */
  recertIntervalDays Int           @default(90)
  visitsAuthorized   Int?
  visitsCompleted    Int           @default(0)
  /** DISCHARGED close-out reason (optional). */
  closeReason        String?
  /** DISCHARGED → ACTIVE re-open reason (required at API). */
  reopenReason       String?

  goals             EpisodeGoal[]
  encounters        Encounter[]
  followUps         FollowUp[]
  snapshotOverrides SnapshotOverride[]
  externalContexts  ExternalContext[]
  schedules         Schedule[]

  @@index([patientId, status])
  @@index([orgId, status, recertDueAt])
}

model EpisodeGoal {
  id              String        @id @default(cuid())
  episodeId       String
  episode         EpisodeOfCare @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  goalType        GoalType
  goalText        String
  baselineMeasure String?
  targetMeasure   String?
  currentMeasure  String?
  status          GoalStatus    @default(ACTIVE)
  originNoteId    String? // set when goal was created in a note (Unit 05)
  resolvedNoteId  String? // set when goal status changed (Unit 05)
  createdAt       DateTime      @default(now())

  progressEntries GoalProgressEntry[]
}

model GoalProgressEntry {
  id            String      @id @default(cuid())
  goalId        String
  goal          EpisodeGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  /** Optional — present when the entry was captured inside a note (Unit 05);
   *  absent when captured directly from the patient detail (Unit 11). */
  noteId        String?
  /** Optional — when the entry records a status transition (Unit 11) instead
   *  of a measurement, measureValue stays null. */
  measureValue  String?
  /** Status snapshot at the time of the entry (Unit 11). */
  statusAtEntry GoalStatus?
  /** Optional free-text from the clinician explaining the update (Unit 11). */
  deltaNote     String?
  recordedAt    DateTime    @default(now())
  recordedByOrgUserId String?

  @@index([goalId, recordedAt])
}

// =============================================================================
// Note — minimal shell from Unit 02 + Unit 03 capture fields.
// Unit 04/05 will append every other field (draftJson, finalJson, inferenceLog,
// signedAt, signedByUserId, templateId, templateVersion, noteStyle,
// sensitivityLevel, …).
// =============================================================================
model Note {
  id                 String     @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient    @relation(fields: [patientId], references: [id])
  encounterId        String?
  encounter          Encounter? @relation(fields: [encounterId], references: [id])
  clinicianOrgUserId String
  division           Division
  status             NoteStatus @default(PREPARING)

  // Unit 03 — capture-mode metadata + transcript pre-AI-generation.
  captureMode     CaptureMode @default(LIVE)
  audioFileKey    String? // S3 key for the consolidated audio blob (rule 7: never hard-deleted)
  transcriptRaw   Json? // raw Soniox payload (final transcript + speaker tags) — Unit 04 cleans this into transcriptClean
  transcriptClean Json? // post-processed transcript (Unit 04 cleans LIVE/UPLOADED; Unit 03 writes PASTED directly)

  // Unit 04 — worker pipeline metadata.
  // inferenceLog tracks per-section AI generation state (Unit 05 writes
  // _sectionStatus + _regenerations), worker retry counts, and recent
  // transitions. PHI-free shape; never embed transcript content or patient
  // identifiers in here.
  inferenceLog    Json?
  interruptedAt   DateTime? // set when a worker hits its retry limit
  lastWorkerError String? // class + message of the last fatal failure (PHI-free)

  // Unit 05 — note generation + sign.
  // draftJson holds the in-progress structured note; finalJson is the FROZEN
  // attested artifact (anti-regression rule 3: NEVER modified after sign,
  // addenda are NoteArtifact rows). Both are TipTap-flavored JSON ({type:
  // 'doc', content: [...]}) keyed by section id; see lib/notes/sections.ts.
  draftJson Json?
  finalJson Json? // IMMUTABLE after status === SIGNED

  templateId       String?
  template         NoteTemplate?        @relation(fields: [templateId], references: [id])
  templateVersion  Int?
  noteStyle        NoteStyle            @default(HYBRID)
  sensitivityLevel NoteSensitivityLevel @default(STANDARD_CLINICAL)

  signedAt       DateTime?
  signedByUserId String?

  // Backfilled notes (rare; e.g. retroactive entry); not used in Unit 05's
  // happy path but reserved here so the migration matches the kit's
  // architecture.md model definition.
  backfilledAt   DateTime?
  backfillReason String?

  /// Late-entry charting (spec: context/specs/late-entry-charting.md).
  /// dateOfService = the day the underlying care happened (== encounter.startedAt
  /// for a normal same-day visit, backdated for a late entry). signedAt remains
  /// the ACTUAL sign date and is never backdated. isLateEntry is set true when
  /// the clinician documents a past event (>=1 day gap); lateEntryDaysGap is
  /// stamped at note-creation time so the "LATE ENTRY · Nd" badge doesn't
  /// re-derive on every render.
  dateOfService    DateTime @default(now())
  isLateEntry      Boolean  @default(false)
  lateEntryDaysGap Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  audioSegments AudioSegment[]
  artifacts     NoteArtifact[]

  // Unit 06 — prior-context brief precomputed at sign + follow-ups extracted
  // from this note's Plan section.
  briefs           NoteBrief[]
  originFollowUps  FollowUp[]  @relation("FollowUpOrigin")
  closingFollowUps FollowUp[]  @relation("FollowUpClosing")

  // Unit 14 — AI compliance flags surfaced on /review.
  reviewFlags ReviewFlag[]

  // Unit 16 — telehealth session this note belongs to (1:1, optional).
  telehealthSession TelehealthSession?

  @@index([orgId, status])
  @@index([patientId, createdAt])
  @@index([patientId, status])
}

// =============================================================================
// NoteTemplate — section schema + prompt hints used by the ai-generation
// worker. Visibility scopes the template to org/team/public; preset templates
// (isPreset=true) ship from the seed and can't be edited by clinicians.
//
// sectionSchema is the canonical shape: { sections: [{ id, label, required?,
// promptHint? }] }. Unit 13 (templates editor maturity) ships the authoring
// surface; Unit 05 ships only the seeded presets.
// =============================================================================
model NoteTemplate {
  id                  String               @id @default(cuid())
  orgId               String?
  organization        Organization?        @relation(fields: [orgId], references: [id])
  name                String
  description         String?
  division            Division
  specialty           String?
  visibility          String // 'PERSONAL' | 'TEAM' | 'PUBLIC'
  isPreset            Boolean              @default(false)
  sectionSchema       Json // { sections: [{ id, label, required?, promptHint? }] }
  promptHints         Json?
  sensitivityDefault  NoteSensitivityLevel @default(STANDARD_CLINICAL)
  version             Int                  @default(1)
  createdByOrgUserId  String?
  /** Unit 13 — source template when this row was cloned (drives version-
   *  history chain). null when this is an original. */
  clonedFromId        String?
  clonedFrom          NoteTemplate?        @relation("TemplateClonedFrom", fields: [clonedFromId], references: [id])
  clones              NoteTemplate[]       @relation("TemplateClonedFrom")
  /** Unit 13 — soft-delete. Archived templates don't surface in the picker;
   *  the row stays for historical note reference. */
  isArchived          Boolean              @default(false)
  archivedAt          DateTime?
  archivedByOrgUserId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  notes Note[]

  @@index([orgId, division, isPreset])
  @@index([orgId, isArchived])
  @@index([clonedFromId])
}

// =============================================================================
// NoteArtifact — post-sign generated documents. SEPARATE from finalJson
// (rule 3). Patient instructions + referral letters live here. The
// post-sign-artifacts worker writes these AFTER the sign transaction commits.
// =============================================================================
model NoteArtifact {
  id          String           @id @default(cuid())
  noteId      String
  note        Note             @relation(fields: [noteId], references: [id])
  kind        NoteArtifactKind
  content     Json
  generatedAt DateTime         @default(now())

  @@index([noteId, kind])
}

// =============================================================================
// AudioSegment — one per capture stream upload (Unit 03 ships exactly one per
// Note for now; future units may split long sessions into multiple segments).
// Rule 7: audio is NEVER hard-deleted from S3. Soft-delete only.
// Rule 15: presigned URLs only — never make the bucket public.
// =============================================================================
model AudioSegment {
  id           String    @id @default(cuid())
  noteId       String
  note         Note      @relation(fields: [noteId], references: [id])
  segmentIndex Int       @default(0)
  s3Key        String
  durationMs   Int
  sampleRate   Int
  byteSize     Int
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([noteId, segmentIndex])
}

// =============================================================================
// Unit 06 — Prior-Context Brief + Follow-up lifecycle.
//
// NoteBrief is the precomputed 30-second pre-visit brief, 1:1 with a signed
// Note. The note-brief BullMQ worker writes one of these post-sign so the
// NEXT visit's /prepare + /capture surfaces render the brief in <1s from
// cache. Sibling table (not a column on Note) per rule 3: Note.finalJson is
// immutable, but the brief must remain regenerable when the prompt improves.
//
// FollowUp tracks clinician commitments across visits. Created at sign-time
// by the FollowupExtractor from the just-signed note's Plan section.
// Lifecycle: OPEN → MET / CARRIED / DROPPED / CLOSED_BY_DISCHARGE. Status
// changes are audited and gate the sign flow (sign-time sweep modal).
// =============================================================================

enum FollowUpStatus {
  OPEN
  MET
  CARRIED
  DROPPED
  CLOSED_BY_DISCHARGE
}

model NoteBrief {
  id           String       @id @default(cuid())
  noteId       String       @unique
  note         Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient      @relation(fields: [patientId], references: [id])
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  episodeId    String?

  sourceNoteIds    String[]
  generatedAt      DateTime @default(now())
  generatorVersion String
  model            String // 'sonnet' | 'haiku' (we store the family, not the exact ID, for cross-region invalidation)

  // Brief payload — PriorContextBriefContent (Zod-validated at write time).
  // Shape lives in src/types/brief.ts. Stored as Json so prompt evolutions
  // (Phase 13b measureKey registry etc.) don't require a migration.
  content Json

  @@index([patientId, generatedAt])
  @@index([orgId, generatedAt])
}

model FollowUp {
  id           String         @id @default(cuid())
  orgId        String
  organization Organization   @relation(fields: [orgId], references: [id])
  patientId    String
  patient      Patient        @relation(fields: [patientId], references: [id])
  episodeId    String?
  episode      EpisodeOfCare? @relation(fields: [episodeId], references: [id])

  originNoteId  String
  originNote    Note    @relation("FollowUpOrigin", fields: [originNoteId], references: [id])
  closingNoteId String?
  closingNote   Note?   @relation("FollowUpClosing", fields: [closingNoteId], references: [id])

  text              String
  patientFacingText String? // reserved for AVS workstream (deferred)
  status            FollowUpStatus @default(OPEN)
  closingNoteText   String? // required when MET (≥5 chars)
  dropReason        String? // required when DROPPED (≥5 chars)

  closedAt          DateTime?
  closedByOrgUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
  @@index([orgId, status])
  @@index([episodeId])
}

// =============================================================================
// Unit 12 — Patient detail redesign / snapshot strip
//
// SnapshotOverride is the per-(measureKey, scope) clinician-edited override
// for the snapshot strip on /patients/[id]. Soft-deleted via supersededAt
// so the override history is queryable (rule 7-ish: clinical data is never
// hard-deleted). Stored value is a Json to handle scalars, strings, and
// structured measures (e.g. BP {systolic, diastolic}).
//
// scope is implicit in (patientId, episodeId): episodeId set → episode-
// scoped (rehab measures), null → patient-scoped (medical vitals, BH
// totals). The build-snapshot-strip pipeline looks up the latest non-
// superseded row per (measureKey, scope) on every read.
// =============================================================================
model SnapshotOverride {
  id                    String    @id @default(cuid())
  orgId                 String
  patientId             String
  patient               Patient   @relation(fields: [patientId], references: [id])
  episodeId             String?
  episode               EpisodeOfCare? @relation(fields: [episodeId], references: [id])
  measureKey            String
  /** Scalar (number), string ("3+"), or structured object ({systolic, diastolic}).
   *  No Zod validation at the DB layer — the snapshot pipeline coerces to
   *  the registry's expected shape at render time. */
  valueJson             Json
  unit                  String?
  /** Clinician-supplied "as of" time. */
  recordedAt            DateTime
  enteredAt             DateTime  @default(now())
  enteredByOrgUserId    String
  /** Soft-delete: when set, this row is superseded. The latest non-
   *  superseded row per (measureKey, scope) wins. */
  supersededAt          DateTime?
  supersededByOrgUserId String?

  @@index([patientId, measureKey, supersededAt])
  @@index([episodeId, measureKey, supersededAt])
  @@index([orgId, supersededAt])
}

// =============================================================================
// Unit 14 — AI compliance-flag system for /review.
//
// Flag severity (canonical):
//   RED    — contradicts transcript (must resolve before sign)
//   BLUE   — added specifics (clinician confirms or removes)
//   YELLOW — inferred (clinician confirms or rephrases)
//   GREEN  — verified by analyzer; surfaces as resolved-count only
//
// Lifecycle: OPEN → RESOLVED (with action) | DISMISSED. PHI-bearing fields
// (claim / rationale / evidence / suggestion) are clinical content; only the
// analyzer worker + the resolve route + the read endpoint touch them, all
// org-scoped via assertOrgScoped.
// =============================================================================

enum ReviewFlagSeverity {
  RED
  BLUE
  YELLOW
  GREEN
}

enum ReviewFlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model ReviewFlag {
  id                  String             @id @default(cuid())
  noteId              String
  note                Note               @relation(fields: [noteId], references: [id], onDelete: Cascade)
  orgId               String
  sectionId           String
  severity            ReviewFlagSeverity
  status              ReviewFlagStatus   @default(OPEN)
  /** AI-extracted claim from the draft section that triggered the flag. */
  claim               String
  /** Why the AI flagged it — short rationale. */
  rationale           String
  /** Transcript evidence snippet supporting (GREEN) or contradicting (RED)
   *  the claim. May be null for BLUE/YELLOW. */
  evidence            String?
  /** Suggested replacement text (RED especially). */
  suggestion          String?
  /** AI confidence 0..1 — surfaces in UI as small percent. */
  confidence          Float              @default(0.5)
  /** Set when status flips to RESOLVED or DISMISSED. */
  resolvedAt          DateTime?
  resolvedByOrgUserId String?
  /** 'ACCEPT_EDIT' | 'DISMISS_KEEP' | 'REGENERATE_SECTION' | 'AUTO_VERIFIED' */
  resolutionAction    String?
  resolutionNote      String?
  createdAt           DateTime           @default(now())

  @@index([noteId, status])
  @@index([noteId, sectionId])
  @@index([orgId, createdAt])
}

// =============================================================================
// Unit 15 — Telehealth session lifecycle.
//
// 1:1 with a Schedule when visitType=TELEHEALTH. Tracks the magic-link
// auth state, patient consent capture, Daily.co room metadata, and the
// session's overall state machine (SCHEDULED → VERIFIED → CONSENT_CAPTURED
// → ACTIVE → COMPLETED). EXPIRED + CANCELLED are off-happy-path terminal
// states.
//
// Magic-link semantics (spec §A):
//   - 22-char base64url token (~131 bits of entropy)
//   - Expires at min(issuedAt + 24h, scheduledEnd + 2h)
//   - Single-use: verifiedAt set on first successful DOB match; subsequent
//     verifies return generic "invalid link" (anti-enumeration)
//
// Video is NOT an artifact of record. roomUrl + roomName are operational
// metadata for the Daily.co room — they don't reference any recorded asset.
// =============================================================================

enum TelehealthSessionStatus {
  SCHEDULED
  VERIFIED
  CONSENT_CAPTURED
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model TelehealthSession {
  id             String                  @id @default(cuid())
  orgId          String
  organization   Organization            @relation(fields: [orgId], references: [id])
  scheduleId     String                  @unique
  schedule       Schedule                @relation(fields: [scheduleId], references: [id])
  patientId      String
  patient        Patient                 @relation(fields: [patientId], references: [id])
  /** Magic-link token, 22-char URL-safe base64. */
  magicToken     String                  @unique
  /** Token expires at min(issuedAt + 24h, scheduledEnd + 2h). */
  magicExpiresAt DateTime
  /** Set on first successful DOB verify. Single-use. */
  verifiedAt     DateTime?
  /** Set when the patient submits consent. consentVersion captures which
   *  version of the consent text was accepted (Wave 3 polish: the text
   *  lives in a future ConsentTemplate; for v1 it's a free-form string). */
  consentAt      DateTime?
  consentVersion String?
  /** Daily.co room metadata (or stub equivalents when DAILY_API_KEY unset). */
  roomUrl        String?
  roomName       String?
  roomExpiresAt  DateTime?
  status         TelehealthSessionStatus @default(SCHEDULED)
  startedAt      DateTime?
  endedAt        DateTime?
  endedReason    String?
  createdByOrgUserId String?
  /** Unit 16 — Note this session's live transcript writes into. Created in
   *  the same $transaction as the Daily.co room on session start. 1:1; null
   *  until the clinician starts the call. */
  noteId         String?                 @unique
  note           Note?                   @relation(fields: [noteId], references: [id])
  /** Unit 18 — PHI-free call quality metrics written by the /end handler.
   *  Shape: { sampleChunksProcessed, reconnectCount, callDurationMs,
   *  transcriptSegmentCount }. Auditor lens + future ops dashboards. */
  qualityMetrics Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([orgId, status])
  @@index([magicExpiresAt])
}

// =============================================================================
// Unit 19 — FHIR / SMART on FHIR auth foundations (Wave 4 / F1)
// =============================================================================

/**
 * Per-clinician, per-EHR SMART on FHIR token + identity binding.
 *
 * Token columns are AES-256-GCM-encrypted before insert (see
 * src/lib/fhir/token-crypto.ts). The envelope format is versioned so a
 * future key rotation can recognize stale ciphertexts and re-encrypt.
 */
model FhirIdentity {
  id                  String       @id @default(cuid())
  orgId               String
  organization        Organization @relation(fields: [orgId], references: [id])
  clinicianOrgUserId  String
  clinician           OrgUser      @relation("FhirIdentityClinician", fields: [clinicianOrgUserId], references: [id])
  ehrSystem           String       // 'nextgen' | 'epic' | 'cerner' | 'stub'
  fhirBaseUrl         String
  accessTokenEnc      String       @db.Text
  refreshTokenEnc     String       @db.Text
  scope               String       @db.Text
  expiresAt           DateTime
  /** Set on each successful refresh; null until the first refresh fires. */
  refreshedAt         DateTime?
  /** Patient context from the launch (NextGen typically includes it); used
   *  as a hint for Unit 20's identity matching, not as the match itself. */
  launchPatientFhirId String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([clinicianOrgUserId, ehrSystem])
  @@index([orgId, ehrSystem])
}

/**
 * Bidirectional patient ↔ EHR identity mapping. Schema ships in F1 so the
 * launch flow can persist a partial row when the EHR returns patient
 * context; full CRUD + matching UI is F2 / Unit 20.
 */
model PatientFhirIdentity {
  id                  String   @id @default(cuid())
  patientId           String
  patient             Patient  @relation(fields: [patientId], references: [id])
  ehrSystem           String
  fhirPatientId       String
  fhirIdentifier      String?
  /** 'verified' = clinician confirmed | 'high' = strong auto-match | 'manual' = needs review */
  matchConfidence     String
  verifiedAt          DateTime?
  verifiedByOrgUserId String?
  createdAt           DateTime @default(now())

  @@unique([ehrSystem, fhirPatientId])
  @@index([patientId, ehrSystem])
}

/**
 * Cached FHIR resource snapshots. Schema ships in F1; the sync worker
 * that populates it lands in F3 / Unit 21. Sensitivity propagation per
 * 42 CFR Part 2: if the source EHR flagged it, downstream MUST honor.
 */
model FhirCachedResource {
  id               String   @id @default(cuid())
  patientId        String
  patient          Patient  @relation(fields: [patientId], references: [id])
  ehrSystem        String
  resourceType     String
  fhirResourceId   String
  resource         Json
  fetchedAt        DateTime @default(now())
  sensitivityLevel String?

  @@unique([ehrSystem, resourceType, fhirResourceId])
  @@index([patientId, resourceType, fetchedAt])
}

/**
 * Short-lived row that carries SMART launch context between
 * /api/fhir/launch and /api/fhir/callback. The state value is the OAuth
 * `state` parameter (opaque random); the codeVerifier never leaves the
 * server. expiresAt is createdAt + 10 min; periodic sweeper cleans the
 * abandoned rows.
 */
model FhirLaunchState {
  state              String   @id
  orgId              String
  clinicianOrgUserId String
  iss                String
  launchToken        String?
  codeVerifier       String
  redirectUri        String
  ehrSystem          String
  createdAt          DateTime @default(now())
  expiresAt          DateTime

  @@index([expiresAt])
}

/**
 * Per-org EHR connection — Unit 24 / F6 schema only.
 *
 * Houses encrypted client credentials + the FHIR base URL per (org,
 * ehrSystem) tuple. Lets a future unit support multi-EHR-per-org or
 * per-customer credential rotation without an env-var redeploy.
 *
 * v1 ships ZERO callers — the existing NextGen flow stays env-driven
 * (rule 14: client secrets in env / Secrets Manager). When the first
 * paying customer demands Epic / Cerner, the per-org config flow lands
 * with the wiring that reads from this table.
 *
 * Credentials encrypted with the same AES-256-GCM envelope as
 * FhirIdentity tokens (lib/fhir/token-crypto.ts) so the at-rest
 * encryption posture is identical.
 */
model OrgEhrConnection {
  id              String   @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id])
  ehrSystem       String   // matches EhrVendor: 'nextgen' | 'epic' | 'cerner'
  displayName     String
  fhirBaseUrl     String
  clientIdEnc     String   @db.Text
  clientSecretEnc String   @db.Text
  redirectUri     String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orgId, ehrSystem])
  @@index([orgId])
}

// =============================================================================
// External Context — per-patient prior-visit reference material.
//
// Spec: context/specs/external-context-upload.md
//
// Use-cases: audio/transcript from a telehealth visit the patient sent in;
// referring-provider documentation; a prior visit the clinician did but
// never documented; patient-supplied symptom-diary audio.
//
// Never billable, never sign-able. Read-only after upload. Surfaces in the
// Unit 06 brief alongside signed Notes but with lower-confidence framing
// (source-pill provenance "per outside provider note dated YYYY-MM-DD").
//
// Date attribution is split into two columns: `dateOfRecord` is when the
// underlying event happened; `addedAt` is when the row was created. Never
// confuse them.
// =============================================================================

enum ExternalContextSource {
  PATIENT_SUPPLIED      // patient sent audio / transcript
  OUTSIDE_PROVIDER      // referring doc, prior facility
  EARLIER_UNDOCUMENTED  // visit clinician did but never documented
  CLINICIAN_NOTES       // free-text recollection
  OTHER
}

enum ExternalContextStatus {
  PENDING_TRANSCRIPTION  // audio uploaded, batch job queued
  READY                  // transcript + (optional) audio stored
  FAILED                 // transcription failed; transcript not available
}

model ExternalContext {
  id                String   @id @default(cuid())
  orgId             String
  organization      Organization @relation(fields: [orgId], references: [id])
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id])
  episodeOfCareId   String?
  episode           EpisodeOfCare? @relation(fields: [episodeOfCareId], references: [id])

  /// Date the underlying event happened — NOT when the row was created.
  dateOfRecord      DateTime
  source            ExternalContextSource
  /// Optional human note about the source ("Dr. Smith referral letter",
  /// "patient phone follow-up", etc.).
  sourceLabel       String?

  /// Free-text recollection / paste-in transcript / batch transcript output.
  /// Always present once status === READY. For PENDING_TRANSCRIPTION rows
  /// (upload mode pre-worker) this is the empty string; the worker overwrites
  /// it when the Soniox batch completes.
  transcriptClean   String
  /// Soniox batch result raw form (if from audio upload). Null when transcript
  /// was pasted directly.
  transcriptRaw     Json?
  /// S3 key for the source audio. Null when transcript-only.
  audioFileKey      String?

  status            ExternalContextStatus

  addedAt           DateTime @default(now())
  addedByOrgUserId  String
  addedBy           OrgUser  @relation("ExternalContextAddedBy", fields: [addedByOrgUserId], references: [id])

  @@index([patientId, dateOfRecord])
  @@index([orgId])
}

// -----------------------------------------------------------------------------
// Multi-site clinician enrollment
// Spec: context/specs/clinician-site-enrollment.md
//
// Append-only (rule 1): no existing tables touched. Models the explicit
// clinician ↔ site link. Org-wide roles (ORG_ADMIN+, PLATFORM_*) implicitly
// cover every site via the `getClinicianSiteIds` helper without needing rows
// here.
// -----------------------------------------------------------------------------

model OrgUserSite {
  id        String  @id @default(cuid())
  orgUserId String
  orgUser   OrgUser @relation("OrgUserSiteMember", fields: [orgUserId], references: [id], onDelete: Cascade)
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id])

  /// True for the clinician's primary/home site. UI defaults (schedule
  /// "My sites" filter, patient creation default siteId) use this.
  isPrimary       Boolean  @default(false)

  /// Free-text scope notes — "OR privileges", "evening shift only",
  /// "supervision required". Surfaced in admin UI; not enforced.
  credentialNotes String?

  enrolledAt         DateTime @default(now())
  enrolledByOrgUserId String?
  enrolledBy         OrgUser? @relation("OrgUserSiteEnroller", fields: [enrolledByOrgUserId], references: [id])

  @@unique([orgUserId, siteId])
  @@index([siteId])
}
