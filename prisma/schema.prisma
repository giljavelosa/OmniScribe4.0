/// Sprint 0.11 — ICD-anchored patient-care umbrella. Every encounter links here.
model CaseManagement {
  id                     String               @id @default(cuid())
  orgId                  String
  organization           Organization         @relation(fields: [orgId], references: [id])
  patientId              String
  patient                Patient              @relation(fields: [patientId], references: [id])
  primaryIcd             String?
  primaryIcdLabel        String
  secondaryIcd           String?
  secondaryIcdLabel      String?
  /// Migrated from legacy EpisodeOfCare.bodyPart when present.
  description            String?
  /// Unit 49 — division stamp set at case creation, immutable thereafter.
  /// Set from `openedByOrgUserId → OrgUser.division` on insert (or department
  /// division / `MULTI` as fallbacks during backfill). Only same-division
  /// clinicians (or `MULTI`) may write to this case; enforced via
  /// `assertCanContinueCase` (`src/lib/case-access.ts`).
  division               Division
  status                 CaseManagementStatus @default(ACTIVE)
  openedByOrgUserId      String?
  openedAt               DateTime             @default(now())
  closedAt               DateTime?
  closedByOrgUserId      String?
  closeReason            String?
  /// Sprint 0.13 — forward-compatible with Sprint 0.15's FHIR phase. Set when
  /// the case opens from a verified FHIR Condition; null until then.
  mirrorsFhirConditionId String?

  episodes               EpisodeOfCare[]
  encounters             Encounter[]
  // Sprint 0.16 — FHIR reconciliation drift log (back-relation only).
  fhirDriftLogs          CaseFhirDriftLog[]
  // Sprint 0.17 — FHIR write-back proposals (back-relation only).
  fhirWriteBackProposals FhirWriteBackProposal[]

  @@index([orgId, patientId, status])
  @@index([orgId, patientId, division, status])
  @@index([orgId, primaryIcd])
}

/// Sprint 0.13 — Miss Cleo's case-routing proposal for a single Note.
///
/// One row per Note (1:1) written by the case-router BullMQ worker after
/// AI-generation completes. Captures the AI proposal (with reasoning +
/// confidence), the model that produced it, and the clinician's eventual
/// accept / override decision. Pairs with three append-only audit actions
/// (CASE_ROUTER_PROPOSED / _ACCEPTED / _OVERRIDDEN) so a regulator can
/// reconstruct *every* routing decision end-to-end.
///
/// Rule 20: the agent reads only SIGNED/TRANSFERRED notes, clinician-
/// confirmed FollowUp rows, and verified FHIR resources. Rule 24: the
/// agent does data routing only — never clinical recommendations.
model CaseRouterRun {
  id                     String                  @id @default(cuid())
  orgId                  String
  organization           Organization            @relation(fields: [orgId], references: [id])
  noteId                 String                  @unique
  note                   Note                    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  /// Strict CaseRouterProposal (see src/services/copilot/case-router.ts).
  /// Zod-validated at write time; stored as Json so additive Sprint 0.15
  /// fields (e.g. open-new-from-condition) don't require a migration.
  proposalJson           Json
  confidence             RouterConfidence
  reasoning              String
  /// Bedrock model id family (e.g. 'sonnet', 'haiku', or 'stub') so the
  /// auditor can filter "all decisions made by model X" without an extra
  /// join. Full model id is in the audit metadata.
  modelVersion           String
  createdAt              DateTime                @default(now())
  /// 'accepted' | 'overridden-attach' | 'overridden-open-new'
  /// | 'overridden-attach-with-secondary' | 'overridden-manual'
  acceptedAction         String?
  acceptedAt             DateTime?
  acceptedByUserId       String?
  acceptedBy             User?                   @relation("CaseRouterAcceptedBy", fields: [acceptedByUserId], references: [id])
  // Sprint 0.16 — drift logs written during this run (back-relation only).
  driftLogs              CaseFhirDriftLog[]
  // Sprint 0.17 — FHIR write-back proposals lineage'd to this run.
  fhirWriteBackProposals FhirWriteBackProposal[] @relation("FhirWriteBackByRun")

  @@index([orgId, createdAt])
}

/// Sprint 0.16 — FHIR Phase D₂ reconciliation log.
///
/// One row per detected drift between an OmniScribe `CaseManagement` and
/// its mirrored FHIR `Condition`. Written by the case-router worker on
/// the same run that produced the `reconcile` proposal; resolved by the
/// accept endpoint when the clinician picks a resolution option.
///
/// Anti-regression rule 8: every write here (detect + resolve) pairs with
/// an audit row (`CASE_FHIR_DRIFT_DETECTED` / `CASE_FHIR_DRIFT_RESOLVED`)
/// that NEVER lives inside a swallowing try-catch.
///
/// Anti-regression rule 20: the snapshots below are populated from
/// `verified` `PatientFhirIdentity` cache rows (see Sprint 0.15's fetcher);
/// no draft Note or unverified resource ever lands here.
///
/// Open vs. resolved is the `resolvedAt IS NULL` predicate; the
/// `(caseManagementId, resolvedAt)` index supports "open drifts on this
/// case" queries (Cleo's state-builder + the chart-side drift banner).
model CaseFhirDriftLog {
  id               String         @id @default(cuid())
  orgId            String
  organization     Organization   @relation(fields: [orgId], references: [id])
  patientId        String
  patient          Patient        @relation(fields: [patientId], references: [id])
  caseManagementId String
  caseManagement   CaseManagement @relation(fields: [caseManagementId], references: [id])
  fhirConditionId  String

  driftKind CaseFhirDriftKind

  /// Snapshot at detection — both sides. Lets a regulator reconstruct
  /// "what did the two systems each say at the moment Cleo flagged it?"
  /// without joining the live FHIR cache or replaying the worker.
  caseStatusAtDetection        CaseManagementStatus
  caseIcdAtDetection           String?
  caseIcdLabelAtDetection      String?
  /// FHIR clinicalStatus code as observed (`active` / `recurrence` /
  /// `relapse` / `resolved` / `remission`). String — the FHIR R4 value-set
  /// is too broad to enum-lock yet.
  conditionStatusAtDetection   String
  conditionIcdAtDetection      String
  conditionIcdLabelAtDetection String

  detectedAt      DateTime       @default(now())
  /// FK to the `CaseRouterRun` that detected this drift. Nullable to
  /// reserve room for Sprint 0.18's background-sweep detector — for
  /// Sprint 0.16 this is ALWAYS set.
  detectedByRunId String?
  detectedByRun   CaseRouterRun? @relation(fields: [detectedByRunId], references: [id])

  /// Resolution — null until the clinician picks an option at /review.
  /// Pair updated atomically with the case mutation inside the accept
  /// endpoint's transaction.
  resolvedAt             DateTime?
  /// 'reopen-case' | 'open-new-case' | 'close-case' | 'attach-as-is' |
  /// 'update-case-icd' — the enum of resolution kinds the agent + UI
  /// surface. Kept as a string (vs. a DB enum) so future kinds add
  /// without a migration.
  resolvedAction         String?
  resolvedByUserId       String?
  resolvedBy             User?                   @relation("CaseFhirDriftResolvedBy", fields: [resolvedByUserId], references: [id])
  // Sprint 0.17 — write-back proposals that resolved this drift via
  // a PATCH (close-case / update-case-icd / reopen-case).
  fhirWriteBackProposals FhirWriteBackProposal[] @relation("FhirWriteBackByDrift")

  @@index([orgId, patientId, resolvedAt])
  @@index([caseManagementId, resolvedAt])
  @@index([detectedAt])
}

model Encounter {
  id                 String          @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient         @relation(fields: [patientId], references: [id])
  scheduleId         String?         @unique
  schedule           Schedule?       @relation(fields: [scheduleId], references: [id])
  clinicianOrgUserId String
  siteId             String
  roomId             String?
  departmentId       String?
  department         Department?     @relation(fields: [departmentId], references: [id])
  caseManagementId   String
  caseManagement     CaseManagement  @relation(fields: [caseManagementId], references: [id])
  episodeOfCareId    String?
  episode            EpisodeOfCare?  @relation(fields: [episodeOfCareId], references: [id])
  status             EncounterStatus @default(PLANNED)
  startedAt          DateTime?
  endedAt            DateTime?

  /// Unit 48 — clinical intent of THIS encounter (IE / Daily / Progress /
  /// Re-eval / Discharge for REHAB; equivalents for BH + MEDICAL). Set at
  /// create time; shapes downstream brief spine + (future) compliance
  /// flags + template default. Defaults to UNSPECIFIED so pre-Unit-48
  /// encounters and any caller that omits the field behave as before.
  intent       EncounterIntent @default(UNSPECIFIED)
  /// Unit 48 — provenance for `intent`: CLINICIAN (picked or overrode),
  /// COPILOT_PROPOSAL_CONFIRMED (took Cleo's default), SCHEDULE (inherited).
  intentSource IntentSource    @default(CLINICIAN)

  notes Note[]

  @@index([patientId, startedAt])
  @@index([caseManagementId])
}

/// REHAB-only plan of care nested under CaseManagement (DB CHECK in migration).
model EpisodeOfCare {
  id                 String         @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient        @relation(fields: [patientId], references: [id])
  caseManagementId   String
  caseManagement     CaseManagement @relation(fields: [caseManagementId], references: [id])
  clinicianOrgUserId String
  departmentId       String
  department         Department     @relation(fields: [departmentId], references: [id])
  division           Division
  /// Legacy free-text diagnosis — retained; mirrors primaryIcdLabel for display.
  diagnosis          String
  bodyPart           String?
  primaryIcd         String?
  primaryIcdLabel    String?
  secondaryIcd       String?
  secondaryIcdLabel  String?
  status             EpisodeStatus  @default(ACTIVE)
  startedAt          DateTime       @default(now())
  endedAt            DateTime?
  recertDueAt        DateTime?
  /**
   * Configurable per-episode recert cadence. Default 90 days; API layer
   * enforces min 7, max 365 (Unit 11).
   */
  recertIntervalDays Int            @default(90)
  visitsAuthorized   Int?
  visitsCompleted    Int            @default(0)
  /**
   * DISCHARGED close-out reason (optional).
   */
  closeReason        String?
  /**
   * DISCHARGED → ACTIVE re-open reason (required at API).
   */
  reopenReason       String?

  goals             EpisodeGoal[]
  encounters        Encounter[]
  followUps         FollowUp[]
  snapshotOverrides SnapshotOverride[]
  externalContexts  ExternalContext[]
  schedules         Schedule[]

  @@index([patientId, status])
  @@index([orgId, status, recertDueAt])
}

model EpisodeGoal {
  id              String        @id @default(cuid())
  episodeId       String
  episode         EpisodeOfCare @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  goalType        GoalType
  goalText        String
  baselineMeasure String?
  targetMeasure   String?
  currentMeasure  String?
  status          GoalStatus    @default(ACTIVE)
  originNoteId    String? // set when goal was created in a note (Unit 05)
  resolvedNoteId  String? // set when goal status changed (Unit 05)
  createdAt       DateTime      @default(now())

  progressEntries GoalProgressEntry[]
}

model GoalProgressEntry {
  id                  String      @id @default(cuid())
  goalId              String
  goal                EpisodeGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  /**
   * Optional — present when the entry was captured inside a note (Unit 05);
   * absent when captured directly from the patient detail (Unit 11).
   */
  noteId              String?
  /**
   * Optional — when the entry records a status transition (Unit 11) instead
   * of a measurement, measureValue stays null.
   */
  measureValue        String?
  /**
   * Status snapshot at the time of the entry (Unit 11).
   */
  statusAtEntry       GoalStatus?
  /**
   * Optional free-text from the clinician explaining the update (Unit 11).
   */
  deltaNote           String?
  recordedAt          DateTime    @default(now())
  recordedByOrgUserId String?

  @@index([goalId, recordedAt])
}

// =============================================================================
// Note — minimal shell from Unit 02 + Unit 03 capture fields.
// Unit 04/05 will append every other field (draftJson, finalJson, inferenceLog,
// signedAt, signedByUserId, templateId, templateVersion, noteStyle,
// sensitivityLevel, …).
// =============================================================================
model Note {
  id                 String     @id @default(cuid())
  orgId              String
  patientId          String
  patient            Patient    @relation(fields: [patientId], references: [id])
  encounterId        String?
  encounter          Encounter? @relation(fields: [encounterId], references: [id])
  clinicianOrgUserId String
  division           Division
  status             NoteStatus @default(PREPARING)

  // Unit 03 — capture-mode metadata + transcript pre-AI-generation.
  captureMode     CaptureMode @default(LIVE)
  audioFileKey    String? // S3 key for the consolidated audio blob (rule 7: never hard-deleted)
  transcriptRaw   Json? // raw Soniox payload (final transcript + speaker tags) — Unit 04 cleans this into transcriptClean
  transcriptClean Json? // post-processed transcript (Unit 04 cleans LIVE/UPLOADED; Unit 03 writes PASTED directly)

  // Unit 04 — worker pipeline metadata.
  // inferenceLog tracks per-section AI generation state (Unit 05 writes
  // _sectionStatus + _regenerations), worker retry counts, and recent
  // transitions. PHI-free shape; never embed transcript content or patient
  // identifiers in here.
  inferenceLog    Json?
  interruptedAt   DateTime? // set when a worker hits its retry limit
  lastWorkerError String? // class + message of the last fatal failure (PHI-free)

  // Unit 05 — note generation + sign.
  // draftJson holds the in-progress structured note; finalJson is the FROZEN
  // attested artifact (anti-regression rule 3: NEVER modified after sign,
  // addenda are NoteArtifact rows). Both are TipTap-flavored JSON ({type:
  // 'doc', content: [...]}) keyed by section id; see lib/notes/sections.ts.
  draftJson Json?
  finalJson Json? // IMMUTABLE after status === SIGNED

  templateId       String?
  template         NoteTemplate?        @relation(fields: [templateId], references: [id])
  templateVersion  Int?
  noteStyle        NoteStyle            @default(HYBRID)
  sensitivityLevel NoteSensitivityLevel @default(STANDARD_CLINICAL)

  signedAt       DateTime?
  signedByUserId String?

  // Backfilled notes (rare; e.g. retroactive entry); not used in Unit 05's
  // happy path but reserved here so the migration matches the kit's
  // architecture.md model definition.
  backfilledAt   DateTime?
  backfillReason String?

  /// Late-entry charting (spec: context/specs/late-entry-charting.md).
  /// dateOfService = the day the underlying care happened (== encounter.startedAt
  /// for a normal same-day visit, backdated for a late entry). signedAt remains
  /// the ACTUAL sign date and is never backdated. isLateEntry is set true when
  /// the clinician documents a past event (>=1 day gap); lateEntryDaysGap is
  /// stamped at note-creation time so the "LATE ENTRY · Nd" badge doesn't
  /// re-derive on every render.
  dateOfService    DateTime @default(now())
  isLateEntry      Boolean  @default(false)
  lateEntryDaysGap Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  audioSegments AudioSegment[]
  artifacts     NoteArtifact[]

  // Unit 06 — prior-context brief precomputed at sign + follow-ups extracted
  // from this note's Plan section.
  briefs           NoteBrief[]
  originFollowUps  FollowUp[]  @relation("FollowUpOrigin")
  closingFollowUps FollowUp[]  @relation("FollowUpClosing")

  // Unit 14 — AI compliance flags surfaced on /review.
  reviewFlags ReviewFlag[]

  // Unit 16 — telehealth session this note belongs to (1:1, optional).
  telehealthSession TelehealthSession?

  // Sprint 0.13 — Miss Cleo's case-router proposal for this note (1:1, optional).
  caseRouterRun CaseRouterRun?

  @@index([orgId, status])
  @@index([patientId, createdAt])
  @@index([patientId, status])
}

// =============================================================================
// NoteTemplate — section schema + prompt hints used by the ai-generation
// worker. Visibility scopes the template to org/team/public; preset templates
// (isPreset=true) ship from the seed and can't be edited by clinicians.
//
// sectionSchema is the canonical shape: { sections: [{ id, label, required?,
// promptHint? }] }. Unit 13 (templates editor maturity) ships the authoring
// surface; Unit 05 ships only the seeded presets.
// =============================================================================
model NoteTemplate {
  id                  String               @id @default(cuid())
  orgId               String?
  organization        Organization?        @relation(fields: [orgId], references: [id])
  name                String
  description         String?
  division            Division
  specialty           String?
  visibility          String // 'PERSONAL' | 'TEAM' | 'PUBLIC'
  isPreset            Boolean              @default(false)
  sectionSchema       Json // { sections: [{ id, label, required?, promptHint? }] }
  promptHints         Json?
  sensitivityDefault  NoteSensitivityLevel @default(STANDARD_CLINICAL)
  version             Int                  @default(1)
  createdByOrgUserId  String?
  /**
   * Unit 13 — source template when this row was cloned (drives version-
   * history chain). null when this is an original.
   */
  clonedFromId        String?
  clonedFrom          NoteTemplate?        @relation("TemplateClonedFrom", fields: [clonedFromId], references: [id])
  clones              NoteTemplate[]       @relation("TemplateClonedFrom")
  /**
   * Unit 13 — soft-delete. Archived templates don't surface in the picker;
   * the row stays for historical note reference.
   */
  isArchived          Boolean              @default(false)
  archivedAt          DateTime?
  archivedByOrgUserId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  notes Note[]

  @@index([orgId, division, isPreset])
  @@index([orgId, isArchived])
  @@index([clonedFromId])
}

// =============================================================================
// NoteArtifact — post-sign generated documents. SEPARATE from finalJson
// (rule 3). Patient instructions + referral letters live here. The
// post-sign-artifacts worker writes these AFTER the sign transaction commits.
// =============================================================================
model NoteArtifact {
  id          String           @id @default(cuid())
  noteId      String
  note        Note             @relation(fields: [noteId], references: [id])
  kind        NoteArtifactKind
  content     Json
  generatedAt DateTime         @default(now())

  @@index([noteId, kind])
}

// =============================================================================
// AudioSegment — one per capture stream upload (Unit 03 ships exactly one per
// Note for now; future units may split long sessions into multiple segments).
// Rule 7: audio is NEVER hard-deleted from S3. Soft-delete only.
// Rule 15: presigned URLs only — never make the bucket public.
// =============================================================================
model AudioSegment {
  id           String    @id @default(cuid())
  noteId       String
  note         Note      @relation(fields: [noteId], references: [id])
  segmentIndex Int       @default(0)
  s3Key        String
  durationMs   Int
  sampleRate   Int
  byteSize     Int
  /// MIME type of the uploaded or recorded audio (e.g. "audio/wav", "audio/mpeg").
  /// Null for segments created before this field was added (LIVE captures pre-2026-05-21).
  mimeType     String?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([noteId, segmentIndex])
}

// =============================================================================
// Voice-ID — Sprint A (polish-waves-0-6 W0-01 + W0-02).
//
// VoiceProfile stores a 192-dimensional TitaNet x-vector embedding per
// enrolled clinician. The transcription worker uses pgvector cosine distance
// to match Soniox diarized speaker windows to enrolled profiles and rewrite
// Note.transcriptClean.structured[].speaker from numeric to CLINICIAN/PATIENT.
//
// BIPA compliance: explicit consent versioning required before enrollment.
// Soft-delete: isDeleted + deletedAt track revocations; hard-delete forbidden
// for 30 days (hardDeleteAt) so that period can be reversed on appeal.
//
// Rule 7 extension: the enrollment audio S3 key follows the same never-hard-
// delete lifecycle as recording audio.
// =============================================================================

model VoiceProfile {
  id              String                      @id @default(cuid())
  orgUserId       String
  orgUser         OrgUser                     @relation(fields: [orgUserId], references: [id])
  orgId           String
  /// 192-dim TitaNet x-vector stored as pgvector; null until the
  /// compute-enrollment-embedding worker completes.
  embedding       Unsupported("vector(192)")?
  /// S3 key of the enrollment audio sample (30–60 s WAV).
  enrollmentS3Key String?
  /// Semantic version of the BIPA consent text the clinician accepted.
  consentVersion  String
  consentedAt     DateTime
  /// Human-readable label e.g. "My Voice" or the user's display name.
  displayName     String?
  /// Heuristic default role used during transcript matching.
  defaultRole     String                      @default("CLINICIAN")
  isDeleted       Boolean                     @default(false)
  deletedAt       DateTime?
  /// 30-day window during which the record can be restored; hard-delete
  /// allowed after this date by a scheduled ops sweep (not auto-deleted).
  hardDeleteAt    DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@unique([orgUserId])
  @@index([orgId, isDeleted])
}

// =============================================================================
// Unit 06 — Prior-Context Brief + Follow-up lifecycle.
//
// NoteBrief is the precomputed 30-second pre-visit brief, 1:1 with a signed
// Note. The note-brief BullMQ worker writes one of these post-sign so the
// NEXT visit's /prepare + /capture surfaces render the brief in <1s from
// cache. Sibling table (not a column on Note) per rule 3: Note.finalJson is
// immutable, but the brief must remain regenerable when the prompt improves.
//
// FollowUp tracks clinician commitments across visits. Created at sign-time
// by the FollowupExtractor from the just-signed note's Plan section.
// Lifecycle: OPEN → MET / CARRIED / DROPPED / CLOSED_BY_DISCHARGE. Status
// changes are audited and gate the sign flow (sign-time sweep modal).
// =============================================================================

enum FollowUpStatus {
  PROPOSED // Sprint pre-sign-followup-suggest — Cleo proposal awaiting clinician triage
  OPEN
  MET
  CARRIED
  DROPPED
  CLOSED_BY_DISCHARGE
}

model NoteBrief {
  id           String       @id @default(cuid())
  noteId       String       @unique
  note         Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient      @relation(fields: [patientId], references: [id])
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  episodeId    String?

  sourceNoteIds    String[]
  generatedAt      DateTime @default(now())
  generatorVersion String
  model            String // 'sonnet' | 'haiku' (we store the family, not the exact ID, for cross-region invalidation)

  // Brief payload — PriorContextBriefContent (Zod-validated at write time).
  // Shape lives in src/types/brief.ts. Stored as Json so prompt evolutions
  // (Phase 13b measureKey registry etc.) don't require a migration.
  content Json

  @@index([patientId, generatedAt])
  @@index([orgId, generatedAt])
}

model FollowUp {
  id           String         @id @default(cuid())
  orgId        String
  organization Organization   @relation(fields: [orgId], references: [id])
  patientId    String
  patient      Patient        @relation(fields: [patientId], references: [id])
  episodeId    String?
  episode      EpisodeOfCare? @relation(fields: [episodeId], references: [id])

  originNoteId  String
  originNote    Note    @relation("FollowUpOrigin", fields: [originNoteId], references: [id])
  closingNoteId String?
  closingNote   Note?   @relation("FollowUpClosing", fields: [closingNoteId], references: [id])

  text              String
  patientFacingText String? // reserved for AVS workstream (deferred)
  status            FollowUpStatus @default(OPEN)
  closingNoteText   String? // required when MET (≥5 chars)
  dropReason        String? // required when DROPPED (≥5 chars)

  /// Unit 49 PR2 — division stamp inherited from origin note at creation.
  /// Closes the cross-division triage hole: a clinician from a different
  /// division cannot mark another division's follow-up as MET/DROPPED/
  /// CARRIED (enforced via assertCanTriageFollowUp + 403 +
  /// CASE_DIVISION_BLOCKED audit). Brief query filters by viewer division
  /// so a PT brief does not surface a BH clinician's follow-ups (the BH
  /// clinician sees them in THEIR division's brief).
  /// Orphan rows (origin note deleted) backfill to MULTI as the escape
  /// hatch; MULTI passes the gate for any division.
  division Division

  // Sprint pre-sign-followup-suggest — provenance for Cleo-proposed rows
  // (status=PROPOSED). All three are NULL for manually-added or post-sign-
  // extracted rows. Kept nullable + additive so existing rows are untouched.
  proposedSourceText       String? @db.Text // ~200-char Plan excerpt the extractor matched on
  proposedExtractorVersion String? // e.g. "followup-extractor-v1"
  proposedFromHash         String? // sha256(planContent) at extraction time — used to skip redundant re-runs

  closedAt          DateTime?
  closedByOrgUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
  @@index([orgId, status])
  @@index([episodeId])
  @@index([originNoteId, status]) // Sprint pre-sign-followup-suggest — fast PROPOSED lookup for a draft note
  @@index([orgId, patientId, division, status]) // Unit 49 PR2 — division-scoped brief + triage queries
}

// =============================================================================
// Unit 12 — Patient detail redesign / snapshot strip
//
// SnapshotOverride is the per-(measureKey, scope) clinician-edited override
// for the snapshot strip on /patients/[id]. Soft-deleted via supersededAt
// so the override history is queryable (rule 7-ish: clinical data is never
// hard-deleted). Stored value is a Json to handle scalars, strings, and
// structured measures (e.g. BP {systolic, diastolic}).
//
// scope is implicit in (patientId, episodeId): episodeId set → episode-
// scoped (rehab measures), null → patient-scoped (medical vitals, BH
// totals). The build-snapshot-strip pipeline looks up the latest non-
// superseded row per (measureKey, scope) on every read.
// =============================================================================
model SnapshotOverride {
  id                    String         @id @default(cuid())
  orgId                 String
  patientId             String
  patient               Patient        @relation(fields: [patientId], references: [id])
  episodeId             String?
  episode               EpisodeOfCare? @relation(fields: [episodeId], references: [id])
  measureKey            String
  /**
   * Scalar (number), string ("3+"), or structured object ({systolic, diastolic}).
   * No Zod validation at the DB layer — the snapshot pipeline coerces to
   * the registry's expected shape at render time.
   */
  valueJson             Json
  unit                  String?
  /**
   * Clinician-supplied "as of" time.
   */
  recordedAt            DateTime
  enteredAt             DateTime       @default(now())
  enteredByOrgUserId    String
  /**
   * Soft-delete: when set, this row is superseded. The latest non-
   * superseded row per (measureKey, scope) wins.
   */
  supersededAt          DateTime?
  supersededByOrgUserId String?

  @@index([patientId, measureKey, supersededAt])
  @@index([episodeId, measureKey, supersededAt])
  @@index([orgId, supersededAt])
}

// =============================================================================
// Unit 14 — AI compliance-flag system for /review.
//
// Flag severity (canonical):
//   RED    — contradicts transcript (must resolve before sign)
//   BLUE   — added specifics (clinician confirms or removes)
//   YELLOW — inferred (clinician confirms or rephrases)
//   GREEN  — verified by analyzer; surfaces as resolved-count only
//
// Lifecycle: OPEN → RESOLVED (with action) | DISMISSED. PHI-bearing fields
// (claim / rationale / evidence / suggestion) are clinical content; only the
// analyzer worker + the resolve route + the read endpoint touch them, all
// org-scoped via assertOrgScoped.
// =============================================================================

enum ReviewFlagSeverity {
  RED
  BLUE
  YELLOW
  GREEN
}

enum ReviewFlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model ReviewFlag {
  id                  String             @id @default(cuid())
  noteId              String
  note                Note               @relation(fields: [noteId], references: [id], onDelete: Cascade)
  orgId               String
  sectionId           String
  severity            ReviewFlagSeverity
  status              ReviewFlagStatus   @default(OPEN)
  /**
   * AI-extracted claim from the draft section that triggered the flag.
   */
  claim               String
  /**
   * Why the AI flagged it — short rationale.
   */
  rationale           String
  /**
   * Transcript evidence snippet supporting (GREEN) or contradicting (RED)
   * the claim. May be null for BLUE/YELLOW.
   */
  evidence            String?
  /**
   * Suggested replacement text (RED especially).
   */
  suggestion          String?
  /**
   * AI confidence 0..1 — surfaces in UI as small percent.
   */
  confidence          Float              @default(0.5)
  /**
   * Set when status flips to RESOLVED or DISMISSED.
   */
  resolvedAt          DateTime?
  resolvedByOrgUserId String?
  /**
   * 'ACCEPT_EDIT' | 'DISMISS_KEEP' | 'REGENERATE_SECTION' | 'AUTO_VERIFIED'
   */
  resolutionAction    String?
  resolutionNote      String?
  createdAt           DateTime           @default(now())

  @@index([noteId, status])
  @@index([noteId, sectionId])
  @@index([orgId, createdAt])
}

// =============================================================================
// Unit 15 — Telehealth session lifecycle.
//
// 1:1 with a Schedule when visitType=TELEHEALTH. Tracks the magic-link
// auth state, patient consent capture, Daily.co room metadata, and the
// session's overall state machine (SCHEDULED → VERIFIED → CONSENT_CAPTURED
// → ACTIVE → COMPLETED). EXPIRED + CANCELLED are off-happy-path terminal
// states.
//
// Magic-link semantics (spec §A):
//   - 22-char base64url token (~131 bits of entropy)
//   - Expires at min(issuedAt + 24h, scheduledEnd + 2h)
//   - Single-use: verifiedAt set on first successful DOB match; subsequent
//     verifies return generic "invalid link" (anti-enumeration)
//
// Video is NOT an artifact of record. roomUrl + roomName are operational
// metadata for the Daily.co room — they don't reference any recorded asset.
// =============================================================================

enum TelehealthSessionStatus {
  SCHEDULED
  VERIFIED
  CONSENT_CAPTURED
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model TelehealthSession {
  id                 String                  @id @default(cuid())
  orgId              String
  organization       Organization            @relation(fields: [orgId], references: [id])
  scheduleId         String                  @unique
  schedule           Schedule                @relation(fields: [scheduleId], references: [id])
  patientId          String
  patient            Patient                 @relation(fields: [patientId], references: [id])
  /**
   * Magic-link token, 22-char URL-safe base64.
   */
  magicToken         String                  @unique
  /**
   * Token expires at min(issuedAt + 24h, scheduledEnd + 2h).
   */
  magicExpiresAt     DateTime
  /**
   * Set on first successful DOB verify. Single-use.
   */
  verifiedAt         DateTime?
  /**
   * Set when the patient submits consent. consentVersion captures which
   * version of the consent text was accepted (Wave 3 polish: the text
   * lives in a future ConsentTemplate; for v1 it's a free-form string).
   */
  consentAt          DateTime?
  consentVersion     String?
  /**
   * Daily.co room metadata (or stub equivalents when DAILY_API_KEY unset).
   */
  roomUrl            String?
  roomName           String?
  roomExpiresAt      DateTime?
  status             TelehealthSessionStatus @default(SCHEDULED)
  startedAt          DateTime?
  endedAt            DateTime?
  endedReason        String?
  createdByOrgUserId String?
  /**
   * Unit 16 — Note this session's live transcript writes into. Created in
   * the same $transaction as the Daily.co room on session start. 1:1; null
   * until the clinician starts the call.
   */
  noteId             String?                 @unique
  note               Note?                   @relation(fields: [noteId], references: [id])
  /**
   * Unit 18 — PHI-free call quality metrics written by the /end handler.
   * Shape: { sampleChunksProcessed, reconnectCount, callDurationMs,
   * transcriptSegmentCount }. Auditor lens + future ops dashboards.
   */
  qualityMetrics     Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([orgId, status])
  @@index([magicExpiresAt])
}

// =============================================================================
// Unit 19 — FHIR / SMART on FHIR auth foundations (Wave 4 / F1)
// =============================================================================

/**
 * Per-clinician, per-EHR SMART on FHIR token + identity binding.
 * Token columns are AES-256-GCM-encrypted before insert (see
 * src/lib/fhir/token-crypto.ts). The envelope format is versioned so a
 * future key rotation can recognize stale ciphertexts and re-encrypt.
 */
model FhirIdentity {
  id                  String       @id @default(cuid())
  orgId               String
  organization        Organization @relation(fields: [orgId], references: [id])
  clinicianOrgUserId  String
  clinician           OrgUser      @relation("FhirIdentityClinician", fields: [clinicianOrgUserId], references: [id])
  ehrSystem           String // 'nextgen' | 'epic' | 'cerner' | 'stub'
  fhirBaseUrl         String
  accessTokenEnc      String       @db.Text
  refreshTokenEnc     String       @db.Text
  scope               String       @db.Text
  expiresAt           DateTime
  /**
   * Set on each successful refresh; null until the first refresh fires.
   */
  refreshedAt         DateTime?
  /**
   * Patient context from the launch (NextGen typically includes it); used
   * as a hint for Unit 20's identity matching, not as the match itself.
   */
  launchPatientFhirId String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([clinicianOrgUserId, ehrSystem])
  @@index([orgId, ehrSystem])
}

/**
 * Bidirectional patient ↔ EHR identity mapping. Schema ships in F1 so the
 * launch flow can persist a partial row when the EHR returns patient
 * context; full CRUD + matching UI is F2 / Unit 20.
 */
model PatientFhirIdentity {
  id                  String    @id @default(cuid())
  patientId           String
  patient             Patient   @relation(fields: [patientId], references: [id])
  ehrSystem           String
  fhirPatientId       String
  fhirIdentifier      String?
  /**
   * 'verified' = clinician confirmed | 'high' = strong auto-match | 'manual' = needs review
   */
  matchConfidence     String
  verifiedAt          DateTime?
  verifiedByOrgUserId String?
  createdAt           DateTime  @default(now())

  @@unique([ehrSystem, fhirPatientId])
  @@index([patientId, ehrSystem])
}

/**
 * Cached FHIR resource snapshots. Schema ships in F1; the sync worker
 * that populates it lands in F3 / Unit 21. Sensitivity propagation per
 * 42 CFR Part 2: if the source EHR flagged it, downstream MUST honor.
 */
model FhirCachedResource {
  id               String   @id @default(cuid())
  patientId        String
  patient          Patient  @relation(fields: [patientId], references: [id])
  ehrSystem        String
  resourceType     String
  fhirResourceId   String
  resource         Json
  fetchedAt        DateTime @default(now())
  sensitivityLevel String?

  @@unique([ehrSystem, resourceType, fhirResourceId])
  @@index([patientId, resourceType, fetchedAt])
}

/**
 * Short-lived row that carries SMART launch context between
 * /api/fhir/launch and /api/fhir/callback. The state value is the OAuth
 * `state` parameter (opaque random); the codeVerifier never leaves the
 * server. expiresAt is createdAt + 10 min; periodic sweeper cleans the
 * abandoned rows.
 */
model FhirLaunchState {
  state              String   @id
  orgId              String
  clinicianOrgUserId String
  iss                String
  launchToken        String?
  codeVerifier       String
  redirectUri        String
  ehrSystem          String
  createdAt          DateTime @default(now())
  expiresAt          DateTime

  @@index([expiresAt])
}

/**
 * Per-org EHR connection — Unit 24 / F6 schema only.
 * Houses encrypted client credentials + the FHIR base URL per (org,
 * ehrSystem) tuple. Lets a future unit support multi-EHR-per-org or
 * per-customer credential rotation without an env-var redeploy.
 * v1 ships ZERO callers — the existing NextGen flow stays env-driven
 * (rule 14: client secrets in env / Secrets Manager). When the first
 * paying customer demands Epic / Cerner, the per-org config flow lands
 * with the wiring that reads from this table.
 * Credentials encrypted with the same AES-256-GCM envelope as
 * FhirIdentity tokens (lib/fhir/token-crypto.ts) so the at-rest
 * encryption posture is identical.
 */
model OrgEhrConnection {
  id                       String       @id @default(cuid())
  orgId                    String
  organization             Organization @relation(fields: [orgId], references: [id])
  ehrSystem                String // matches EhrVendor: 'nextgen' | 'epic' | 'cerner'
  displayName              String
  fhirBaseUrl              String
  clientIdEnc              String       @db.Text
  clientSecretEnc          String       @db.Text
  redirectUri              String
  enabled                  Boolean      @default(true)
  /// Sprint 0.17 — FHIR Phase D₃ write-back master toggle. Defaults
  /// FALSE for every existing org (decision 10, backward-compat). When
  /// false, the accept endpoint's behavior is byte-identical to Sprint
  /// 0.16: no proposal rows inserted, no audit emissions, no worker
  /// jobs enqueued. Flipping to true requires an admin click on the
  /// org-settings page; flipping back to false batch-cancels every
  /// PROPOSED / APPROVED proposal for the org.
  writebackEnabled         Boolean      @default(false)
  /// Timestamp of the last toggle-on click (for audit + the
  /// admin-settings "enabled since" copy).
  writebackEnabledAt       DateTime?
  /// Admin user id of the last toggle-on click.
  writebackEnabledByUserId String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@unique([orgId, ehrSystem])
  @@index([orgId])
}

/// Sprint 0.17 — FHIR Phase D₃ write-back proposal log.
///
/// One row per proposed EHR write. Inserted by the accept endpoint
/// (in the same tx as the case mutation) when (a) the org has
/// `writebackEnabled = true`, (b) the action is mutating (open-new /
/// open-new-from-condition / reconcile with a mutating resolution),
/// and (c) for PATCH triggers, the case is already mirrored. Approved
/// by the clinician via the review-panel dialog; executed by the
/// `fhir-writeback` BullMQ worker; status terminal at SUCCEEDED or
/// CANCELLED (FAILED + TRANSIENT remains retryable).
///
/// Anti-regression rule 8: every status transition pairs with a
/// `FHIR_WRITEBACK_*` audit row. The PROPOSED audit lives inside the
/// accept-endpoint tx so a throw rolls both rows back together. The
/// SUCCEEDED / FAILED / CANCELLED audits live OUTSIDE any swallowing
/// try-catch in the worker (the FHIR client returns
/// `{ ok: false, failureKind }` rather than throwing for HTTP failures).
///
/// Anti-regression rule 20: writes target ONLY the org's verified
/// FHIR endpoint bound through `OrgEhrConnection`. The worker
/// re-checks `writebackEnabled` at job pickup — defense in depth
/// (the admin may have flipped the toggle between approve and pickup).
///
/// Decision 2 (idempotency): every proposal carries a `cuid2`
/// `idempotencyKey` at insertion time, sent as the `X-Request-Id`
/// header on the FHIR write. BullMQ jobId is `writeback:{proposalId}`
/// so re-enqueue collapses to the same job. Where the vendor honors
/// `X-Request-Id`, the EHR returns the same resource on retry; where
/// not, the OS-side unique-key dedup prevents double-insertion.
///
/// Decision 4 (no deletes): closing a case PATCHes `clinicalStatus:
/// resolved`; we never DELETE Condition. The FHIR resource history
/// stays in the EHR.
model FhirWriteBackProposal {
  id               String         @id @default(cuid())
  orgId            String
  organization     Organization   @relation(fields: [orgId], references: [id])
  caseManagementId String
  caseManagement   CaseManagement @relation(fields: [caseManagementId], references: [id])
  patientId        String
  patient          Patient        @relation(fields: [patientId], references: [id])
  /// Clinician who confirmed the case action that generated this
  /// proposal (not the same as the eventual approver — though they
  /// often coincide).
  proposedByUserId String
  proposedBy       User           @relation("FhirWriteBackProposedBy", fields: [proposedByUserId], references: [id])

  // ---- Trigger lineage (why this write was proposed) ----
  /// 'open-new' | 'open-new-from-condition' | 'reconcile-with-mutation'
  triggerKind     String
  /// The routing run that surfaced the underlying action.
  caseRouterRunId String?
  caseRouterRun   CaseRouterRun?    @relation("FhirWriteBackByRun", fields: [caseRouterRunId], references: [id])
  /// The drift log resolved (only set for reconcile triggers).
  driftLogId      String?
  driftLog        CaseFhirDriftLog? @relation("FhirWriteBackByDrift", fields: [driftLogId], references: [id])

  // ---- Payload ----
  operation       FhirWriteBackOperation
  /// Null for CREATE; populated for PATCH (the EHR Condition.id this
  /// proposal patches).
  fhirConditionId String?
  /// CREATE: the full FHIR R4 Condition resource. PATCH: the RFC 6902
  /// JSON Patch array. Zod-validated at the service layer (no schema
  /// constraint here — the JSON shape evolves additively).
  payloadJson     Json
  /// The `meta.versionId` captured at proposal time (Sprint 0.16 drift
  /// detection). PATCH only — sent as `If-Match: W/"<version>"` so a
  /// concurrent EHR-side mutation yields a 412 + `failureKind: CONFLICT`
  /// rather than a silent overwrite (decision 6).
  ifMatchVersion  String?
  /// cuid2; sent as `X-Request-Id` on the upstream FHIR call. Unique so
  /// a duplicate proposal-insert attempt fails closed at the DB.
  idempotencyKey  String                 @unique

  // ---- State machine ----
  status            FhirWriteBackStatus @default(PROPOSED)
  proposedAt        DateTime            @default(now())
  approvedAt        DateTime?
  approvedByUserId  String?
  approvedBy        User?               @relation("FhirWriteBackApprovedBy", fields: [approvedByUserId], references: [id])
  executingAt       DateTime?
  succeededAt       DateTime?
  failedAt          DateTime?
  cancelledAt       DateTime?
  cancelledByUserId String?
  cancelledBy       User?               @relation("FhirWriteBackCancelledBy", fields: [cancelledByUserId], references: [id])

  // ---- Outcome (populated by worker) ----
  /// Resource id the EHR returned (CREATE) or echoed back (PATCH).
  resultFhirId      String?
  /// The new `meta.versionId` after a successful CREATE or PATCH.
  resultFhirVersion String?
  failureKind       FhirWriteBackFailureKind?
  /// Sanitized HTTP error — PHI-free (the FHIR client strips any body
  /// containing patient identifiers before persisting).
  failureMessage    String?
  /// Monotonic counter incremented per worker failure. Useful for the
  /// auditor lens ("how often does this org's EHR reject writes?")
  /// without scanning the audit log.
  failureCount      Int                       @default(0)

  @@index([orgId, status])
  @@index([caseManagementId])
  @@index([patientId, status])
  @@index([proposedAt])
}

/// Sprint 0.18 — Cleo's proactive nudge.
///
/// One row per logical nudge (decision 1 — uniqued on
/// `(clinicianOrgUserId, patientId, kind, sourcePatternSnapshotHash)`).
/// The generator runs inside the existing `cleo-state` worker (rule 18:
/// no new BullMQ queue — decision 12) and upserts these rows; the
/// matching `CLEO_NUDGE_PROPOSED` audit is emitted per inserted row
/// outside any swallowing try-catch (rule 8). The clinician sees the
/// nudge in the chart pill (collapsed) or the visit-prepare block
/// (expanded), can act / dismiss / snooze in one tap (decision 6), and
/// the row's state machine progresses to a terminal state (ACTED /
/// DISMISSED / EXPIRED) or non-terminal SNOOZED (re-surfaces at
/// `snoozeUntil`).
///
/// Anti-regression rules:
///   - Rule 20: `sourcePatternSnapshotJson` derives ONLY from rule-20
///     gated sources (SIGNED/TRANSFERRED notes, confirmed FollowUps,
///     verified FHIR-cache rows; plus Sprint-0.17 `FhirWriteBackProposal`
///     rows which are themselves derived from rule-20 sources via the
///     accept endpoint).
///   - Rule 24: nudges SURFACE data + offer a contextual *navigation*;
///     the affordance `affordanceSlug` (e.g. 'open-reconcile-flow')
///     takes the clinician to the screen where THEY decide. The
///     generator is deterministic + rule-based; no LLM call in the
///     nudge pathway (decision 11).
///   - Decision 9: the audit log NEVER stores the rendered label
///     string (which often contains PHI like PHQ-9 values). The label
///     can be reconstructed from `sourcePatternSnapshotJson` at
///     audit-replay time if ever needed.
///
/// Decision 3a (escalation): when a pattern escalates (e.g. recert
/// "due in 14 days" → "due in 3 days"), the generator emits a NEW
/// snapshot hash → a NEW row. The old DISMISSED row is left in place
/// for the cooldown audit; the new row surfaces with full priority.
/// An escalating clinical signal must not get silenced by a stale
/// dismissal.
model CleoNudge {
  id                 String       @id @default(cuid())
  orgId              String
  organization       Organization @relation(fields: [orgId], references: [id])
  patientId          String
  patient            Patient      @relation(fields: [patientId], references: [id])
  /// Per-clinician (Sprint 0.14 projection lineage). One clinician's
  /// dismissal does NOT silence the nudge for their colleague.
  clinicianOrgUserId String
  clinicianOrgUser   OrgUser      @relation(fields: [clinicianOrgUserId], references: [id])

  kind             CleoNudgeKind
  priority         CleoNudgePriority
  /// Where the nudge is eligible to render. CHART / VISIT_PREPARE /
  /// BOTH (most common). Read-time filter narrows by current surface.
  eligibleSurfaces CleoNudgeSurface  @default(BOTH)

  /// Stable hash of the source pattern's identity (e.g.
  /// `goal_stalled:goal_42:since_2026-04-15`). The compound unique
  /// constraint below treats two patterns with the SAME hash as the
  /// SAME logical nudge — re-running the generator is idempotent.
  sourcePatternSnapshotHash String
  /// The pattern detail the detector saw at proposal time. Stored as
  /// JSON so the read-time renderer doesn't need to re-derive from
  /// the latest `observedPatternsJson` (which may have shifted).
  /// PHI-bearing (measure values etc.) — clinical surface only,
  /// never audit metadata.
  sourcePatternSnapshotJson Json
  /// Affordance slug — the categorical action label that records
  /// WHICH path the clinician chose on `_ACTED` (e.g.
  /// 'open-reconcile-flow' / 'start-recert-visit' /
  /// 'open-plan-editor' / 'review-failed-writeback' /
  /// 'reevaluate-goal'). Decision 7 — generic 'open' regresses the
  /// auditor lens.
  affordanceSlug            String

  // ---- State machine ----
  status            CleoNudgeStatus @default(PROPOSED)
  proposedAt        DateTime        @default(now())
  /// First-mount audit fired (decision 5). Subsequent mounts do NOT
  /// re-stamp this field.
  shownAt           DateTime?
  dismissedAt       DateTime?
  dismissedByUserId String?
  dismissedBy       User?           @relation("CleoNudgeDismissedBy", fields: [dismissedByUserId], references: [id])
  snoozedAt         DateTime?
  snoozedByUserId   String?
  snoozedBy         User?           @relation("CleoNudgeSnoozedBy", fields: [snoozedByUserId], references: [id])
  /// Future timestamp; the read filter excludes the row until now ≥ this.
  snoozeUntil       DateTime?
  actedAt           DateTime?
  actedByUserId     String?
  actedBy           User?           @relation("CleoNudgeActedBy", fields: [actedByUserId], references: [id])
  /// The affordance slug the clinician pressed (echoes
  /// `affordanceSlug` on the happy path; may differ if the UI ever
  /// offers a secondary affordance under the same nudge — out of
  /// scope this sprint).
  actedAction       String?
  /// Stamped when the read-time expiry filter flips the row.
  expiredAt         DateTime?

  // ---- Lineage ----
  /// Sprint 0.12 persona-version stamp. Lets a regulator filter
  /// "all Cleo nudges under miss-cleo-v1" in one query.
  personaVersion String @default("miss-cleo-v1")

  /// Decision 1 — one logical nudge per (clinician × patient × kind ×
  /// snapshot-hash). Generator `upsert` uses this compound key so a
  /// re-run on unchanged patterns is a no-op.
  @@unique([clinicianOrgUserId, patientId, kind, sourcePatternSnapshotHash])
  @@index([orgId, patientId, clinicianOrgUserId, status])
  @@index([clinicianOrgUserId, status])
  @@index([proposedAt])
}

// =============================================================================
// External Context — per-patient prior-visit reference material.
//
// Spec: context/specs/external-context-upload.md
//
// Use-cases: audio/transcript from a telehealth visit the patient sent in;
// referring-provider documentation; a prior visit the clinician did but
// never documented; patient-supplied symptom-diary audio.
//
// Never billable, never sign-able. Read-only after upload. Surfaces in the
// Unit 06 brief alongside signed Notes but with lower-confidence framing
// (source-pill provenance "per outside provider note dated YYYY-MM-DD").
//
// Date attribution is split into two columns: `dateOfRecord` is when the
// underlying event happened; `addedAt` is when the row was created. Never
// confuse them.
// =============================================================================

enum ExternalContextSource {
  PATIENT_SUPPLIED // patient sent audio / transcript
  OUTSIDE_PROVIDER // referring doc, prior facility
  EARLIER_UNDOCUMENTED // visit clinician did but never documented
  CLINICIAN_NOTES // free-text recollection
  OTHER
}

enum ExternalContextStatus {
  PENDING_TRANSCRIPTION // audio uploaded, batch job queued
  READY // transcript + (optional) audio stored
  FAILED // transcription failed; transcript not available
}

model ExternalContext {
  id              String         @id @default(cuid())
  orgId           String
  organization    Organization   @relation(fields: [orgId], references: [id])
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  episodeOfCareId String?
  episode         EpisodeOfCare? @relation(fields: [episodeOfCareId], references: [id])

  /// Date the underlying event happened — NOT when the row was created.
  dateOfRecord DateTime
  source       ExternalContextSource
  /// Optional human note about the source ("Dr. Smith referral letter",
  /// "patient phone follow-up", etc.).
  sourceLabel  String?

  /// Free-text recollection / paste-in transcript / batch transcript output.
  /// Always present once status === READY. For PENDING_TRANSCRIPTION rows
  /// (upload mode pre-worker) this is the empty string; the worker overwrites
  /// it when the Soniox batch completes.
  transcriptClean String
  /// Soniox batch result raw form (if from audio upload). Null when transcript
  /// was pasted directly.
  transcriptRaw   Json?
  /// S3 key for the source audio. Null when transcript-only.
  audioFileKey    String?

  status ExternalContextStatus

  addedAt          DateTime @default(now())
  addedByOrgUserId String
  addedBy          OrgUser  @relation("ExternalContextAddedBy", fields: [addedByOrgUserId], references: [id])

  @@index([patientId, dateOfRecord])
  @@index([orgId])
}

// -----------------------------------------------------------------------------
// Multi-site clinician enrollment
// Spec: context/specs/clinician-site-enrollment.md
//
// Append-only (rule 1): no existing tables touched. Models the explicit
// clinician ↔ site link. Org-wide roles (ORG_ADMIN+, PLATFORM_*) implicitly
// cover every site via the `getClinicianSiteIds` helper without needing rows
// here.
// -----------------------------------------------------------------------------

model OrgUserSite {
  id        String  @id @default(cuid())
  orgUserId String
  orgUser   OrgUser @relation("OrgUserSiteMember", fields: [orgUserId], references: [id], onDelete: Cascade)
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id])

  /// True for the clinician's primary/home site. UI defaults (schedule
  /// "My sites" filter, patient creation default siteId) use this.
  isPrimary Boolean @default(false)

  /// Free-text scope notes — "OR privileges", "evening shift only",
  /// "supervision required". Surfaced in admin UI; not enforced.
  credentialNotes String?

  enrolledAt          DateTime @default(now())
  enrolledByOrgUserId String?
  enrolledBy          OrgUser? @relation("OrgUserSiteEnroller", fields: [enrolledByOrgUserId], references: [id])

  @@unique([orgUserId, siteId])
  @@index([siteId])
}

// =============================================================================
// Sprint 0.14 — Miss Cleo's persistent memory + chat threads.
//
// Three additive models + one new enum. No changes to existing tables.
//
//   CopilotPatientState — per-(orgId × patientId × clinicianOrgUserId)
//     projection / cache of what Miss Cleo has learned about this patient
//     from this clinician's vantage. Source of truth remains signed notes +
//     CaseManagement + FollowUp + CaseRouterRun + FHIR; this row is
//     rebuildable on demand from primary sources (rule 20).
//
//   CopilotConversation — one persistent chat thread per
//     (orgId × patientId × clinicianOrgUserId × mode). Research-mode rows
//     have patientId=null; the unique index treats that as a distinct slot.
//
//   CopilotMessage — append-only message rows under a conversation.
//     content may carry PHI; stored under the org's standard at-rest
//     encryption (no separate column encryption — same posture as note
//     bodies). Audit metadata stays PHI-free per rule 8.
// =============================================================================

enum CopilotConversationMode {
  CHART
  RESEARCH
}

/// Per-(patient × clinician) projection cache populated by the cleo-state
/// worker. Source-of-truth remains signed notes + CaseManagement + FollowUp +
/// CaseRouterRun + FHIR. Rebuilt deterministically on signed-note +
/// case-router-accept events. Bump `generatorVersion` when the JSON shape
/// changes so future rebuilds re-emit cleanly.
model CopilotPatientState {
  id                 String @id @default(cuid())
  orgId              String
  patientId          String
  clinicianOrgUserId String

  /// `{ cases: [{id, primaryIcd, primaryIcdLabel, lastViewerActivityAt,
  ///    routingConfidenceHistory, fhirMirror?}] }`. Zod-validated on write.
  caseAwarenessJson     Json
  /// `{ patterns: [{kind, ...detector-specific fields, observedInNoteIds,
  ///    count, firstSeen, lastSeen}] }`. Zod-validated on write.
  observedPatternsJson  Json
  /// `{ facts: [{summary, sourceNoteId?, sourceFollowUpId?,
  ///    sourceConditionId?, citedAt}] }`. Distilled from prior Ask
  ///    assistant turns' source pills (no LLM call in Phase 1).
  conversationFactsJson Json

  lastRebuiltAt    DateTime @default(now()) @updatedAt
  generatorVersion String

  organization     Organization @relation(fields: [orgId], references: [id])
  patient          Patient      @relation(fields: [patientId], references: [id])
  clinicianOrgUser OrgUser      @relation(fields: [clinicianOrgUserId], references: [id])

  @@unique([orgId, patientId, clinicianOrgUserId])
  @@index([orgId, patientId])
  @@index([clinicianOrgUserId, lastRebuiltAt])
}

/// One persistent chat thread per (patient × clinician × mode). Survives
/// browser refresh, re-login, and session expiry. "Reset this conversation"
/// purges the row (cascades to messages); the CopilotPatientState row is
/// untouched — facts are already distilled from primary sources.
model CopilotConversation {
  id                 String                  @id @default(cuid())
  orgId              String
  /// null for RESEARCH-mode conversations (research is patient-agnostic).
  patientId          String?
  clinicianOrgUserId String
  mode               CopilotConversationMode

  startedAt      DateTime @default(now())
  lastActivityAt DateTime @default(now()) @updatedAt
  /// Stamps the persona version at thread-creation time. Lets a regulator
  /// filter "all conversations under miss-cleo-v1" in one query.
  personaVersion String

  messages CopilotMessage[]

  organization     Organization @relation(fields: [orgId], references: [id])
  patient          Patient?     @relation(fields: [patientId], references: [id])
  clinicianOrgUser OrgUser      @relation(fields: [clinicianOrgUserId], references: [id])

  /// One thread per (org × patient × clinician × mode). Research-mode rows
  /// have patientId=NULL — Postgres treats NULL values as distinct under a
  /// unique constraint, so each (org × clinician × RESEARCH) gets its own
  /// research thread, NOT a single global one. A partial unique index in
  /// the migration enforces "one RESEARCH thread per (org × clinician)".
  @@unique([orgId, patientId, clinicianOrgUserId, mode])
  @@index([orgId, clinicianOrgUserId, lastActivityAt])
}

model CopilotMessage {
  id             String   @id @default(cuid())
  conversationId String
  /// 'user' | 'assistant' — kept as plain string (no enum) to mirror the
  /// runtime agent turn shape without an extra migration when we add
  /// 'tool-result' or 'system' in future iterations.
  role           String
  /// May carry PHI. Same at-rest posture as note bodies; audit metadata
  /// stays PHI-free (we never log content + we log length only when needed).
  content        String
  /// Assistant-only: source pills used to render citations + to distill
  /// `conversationFactsJson` in the state builder. `[{kind, id, label}]`.
  sourcesJson    Json?
  /// Assistant-only: tool calls made during this turn (informational).
  toolCallsJson  Json?
  createdAt      DateTime @default(now())

  conversation CopilotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// =============================================================================
// Unit 51 — Commercial capacity: visit bank, user wallets, owner catalog.
// =============================================================================

enum CommercialModel {
  TRIAL
  SOLO_VISIT_BANK
  ORG_VISIT_BANK
  ENTERPRISE_PER_SEAT
  LEGACY_SKU
}

enum VisitCreditBasis {
  COMMITTED
  ACTIVE
}

enum VisitDebitOrder {
  USER_WALLET_THEN_BANK
  BANK_ONLY
}

enum MonthlyAllowancePolicy {
  EXPIRE
  ROLLOVER_USER
  SWEEP_TO_BANK
}

enum VisitLedgerSourceType {
  TRIAL_GRANT
  CONTRACT_BUNDLE
  MONTHLY_ALLOWANCE
  BUNDLE_PURCHASE
  OWNER_GRANT
  ADMIN_ALLOCATE
  ADMIN_RECLAIM
  NOTE_DEBIT
  ADJUSTMENT
  REQUEST_APPROVED
}

enum VisitCapacityRequestStatus {
  PENDING
  APPROVED
  DENIED
}

/// Versioned platform-wide pricing catalog. Owner publishes; org contracts
/// may snapshot `catalogVersion` at signing.
model PlatformBillingCatalog {
  id        String   @id @default(cuid())
  version   Int
  isActive  Boolean  @default(false)
  /// Monthly solo/org tiers: [{ id, label, monthlyPriceCents, monthlyVisitCredit }]
  soloTiersJson Json
  /// One-time top-up packs: [{ id, label, visitCount, priceCents }]
  visitBundlesJson Json
  collaboratorSeatPriceCents Int
  defaultOveragePriceCents   Int
  trialSoloVisits            Int
  trialSoloDays              Int
  trialOrgSeats              Int
  trialOrgVisits             Int
  trialOrgDays               Int
  /// Enterprise template defaults for owner contract form prefill.
  enterpriseTemplateJson Json
  publishedAt       DateTime?
  publishedByUserId String?
  createdAt         DateTime  @default(now())

  commercialContracts OrganizationCommercialContract[]

  @@unique([version])
  @@index([isActive])
}

/// Per-org commercial terms — drives capacity enforcement + owner overrides.
model OrganizationCommercialContract {
  orgId String @id
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  commercialModel CommercialModel @default(TRIAL)
  catalogVersionId  String?
  catalogVersion    PlatformBillingCatalog? @relation(fields: [catalogVersionId], references: [id])

  committedSeats Int @default(1)
  contractStart  DateTime?
  contractEnd    DateTime?

  seatPriceCents          Int?
  visitsPerSeatPerMonth   Int?
  visitCreditBasis        VisitCreditBasis @default(COMMITTED)
  seatBillBasis           VisitCreditBasis @default(COMMITTED)
  monthlyAllowancePolicy  MonthlyAllowancePolicy @default(SWEEP_TO_BANK)
  monthlyAllowanceRolloverCap Int?

  signingBundleVisits Int @default(0)
  overagePriceCents   Int?
  allowOverage        Boolean @default(false)
  allowUserVisitRequests Boolean @default(true)
  visitDebitOrder     VisitDebitOrder @default(USER_WALLET_THEN_BANK)

  /// Solo monthly tier id from catalog (e.g. "solo-pro").
  monthlyTierId String?
  monthlyPriceOverrideCents Int?
  monthlyVisitCreditOverride Int?

  trialEndsAt DateTime?
  capacityEnforcementEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Append-only visit ledger. Positive amount = credit; negative = debit.
model VisitLedgerEntry {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// When set, entry affects user wallet; null = org bank only.
  orgUserId String?
  orgUser   OrgUser? @relation(fields: [orgUserId], references: [id], onDelete: SetNull)

  amount   Int
  orgBankBalanceAfter   Int
  userWalletBalanceAfter Int?

  sourceType VisitLedgerSourceType
  sourceId   String?
  expiresAt  DateTime?
  idempotencyKey String? @unique
  metadata   Json?

  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgUserId, createdAt])
}

model VisitCapacityRequest {
  id                  String @id @default(cuid())
  orgId               String
  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requesterOrgUserId  String
  requester           OrgUser @relation("VisitRequestRequester", fields: [requesterOrgUserId], references: [id], onDelete: Cascade)
  requestedVisits     Int
  message             String? @db.VarChar(500)
  status              VisitCapacityRequestStatus @default(PENDING)
  reviewerOrgUserId   String?
  reviewer            OrgUser? @relation("VisitRequestReviewer", fields: [reviewerOrgUserId], references: [id], onDelete: SetNull)
  responseNote        String? @db.VarChar(500)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orgId, status])
  @@index([requesterOrgUserId, createdAt])
}
